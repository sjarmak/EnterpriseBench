{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019WDb64LYLXzH3ptRX8KuE5","type":"tool_result","content":"1\t/*\n2\tCopyright 2015 The Kubernetes Authors.\n3\t\n4\tLicensed under the Apache License, Version 2.0 (the \"License\");\n5\tyou may not use this file except in compliance with the License.\n6\tYou may obtain a copy of the License at\n7\t\n8\t    http://www.apache.org/licenses/LICENSE-2.0\n9\t\n10\tUnless required by applicable law or agreed to in writing, software\n11\tdistributed under the License is distributed on an \"AS IS\" BASIS,\n12\tWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13\tSee the License for the specific language governing permissions and\n14\tlimitations under the License.\n15\t*/\n16\t\n17\tpackage storage\n18\t\n19\timport (\n20\t\t\"fmt\"\n21\t\t\"sort\"\n22\t\t\"strconv\"\n23\t\t\"sync\"\n24\t\t\"time\"\n25\t\n26\t\t\"k8s.io/apimachinery/pkg/api/errors\"\n27\t\t\"k8s.io/apimachinery/pkg/api/meta\"\n28\t\t\"k8s.io/apimachinery/pkg/fields\"\n29\t\t\"k8s.io/apimachinery/pkg/labels\"\n30\t\t\"k8s.io/apimachinery/pkg/runtime\"\n31\t\t\"k8s.io/apimachinery/pkg/util/clock\"\n32\t\t\"k8s.io/apimachinery/pkg/watch\"\n33\t\tutiltrace \"k8s.io/apiserver/pkg/util/trace\"\n34\t\t\"k8s.io/client-go/tools/cache\"\n35\t)\n36\t\n37\tconst (\n38\t\t// blockTimeout determines how long we're willing to block the request\n39\t\t// to wait for a given resource version to be propagated to cache,\n40\t\t// before terminating request and returning Timeout error with retry\n41\t\t// after suggestion.\n42\t\tblockTimeout = 3 * time.Second\n43\t)\n44\t\n45\t// watchCacheEvent is a single \"watch event\" that is send to users of\n46\t// watchCache. Additionally to a typical \"watch.Event\" it contains\n47\t// the previous value of the object to enable proper filtering in the\n48\t// upper layers.\n49\ttype watchCacheEvent struct {\n50\t\tType                 watch.EventType\n51\t\tObject               runtime.Object\n52\t\tObjLabels            labels.Set\n53\t\tObjFields            fields.Set\n54\t\tObjUninitialized     bool\n55\t\tPrevObject           runtime.Object\n56\t\tPrevObjLabels        labels.Set\n57\t\tPrevObjFields        fields.Set\n58\t\tPrevObjUninitialized bool\n59\t\tKey                  string\n60\t\tResourceVersion      uint64\n61\t}\n62\t\n63\t// Computing a key of an object is generally non-trivial (it performs\n64\t// e.g. validation underneath). To avoid computing it multiple times\n65\t// (to serve the event in different List/Watch requests), in the\n66\t// underlying store we are keeping pair (key, object).\n67\ttype storeElement struct {\n68\t\tKey    string\n69\t\tObject runtime.Object\n70\t}\n71\t\n72\tfunc storeElementKey(obj interface{}) (string, error) {\n73\t\telem, ok := obj.(*storeElement)\n74\t\tif !ok {\n75\t\t\treturn \"\", fmt.Errorf(\"not a storeElement: %v\", obj)\n76\t\t}\n77\t\treturn elem.Key, nil\n78\t}\n79\t\n80\t// watchCacheElement is a single \"watch event\" stored in a cache.\n81\t// It contains the resource version of the object and the object\n82\t// itself.\n83\ttype watchCacheElement struct {\n84\t\tresourceVersion uint64\n85\t\twatchCacheEvent *watchCacheEvent\n86\t}\n87\t\n88\t// watchCache implements a Store interface.\n89\t// However, it depends on the elements implementing runtime.Object interface.\n90\t//\n91\t// watchCache is a \"sliding window\" (with a limited capacity) of objects\n92\t// observed from a watch.\n93\ttype watchCache struct {\n94\t\tsync.RWMutex\n95\t\n96\t\t// Condition on which lists are waiting for the fresh enough\n97\t\t// resource version.\n98\t\tcond *sync.Cond\n99\t\n100\t\t// Maximum size of history window.\n101\t\tcapacity int\n102\t\n103\t\t// keyFunc is used to get a key in the underlying storage for a given object.\n104\t\tkeyFunc func(runtime.Object) (string, error)\n105\t\n106\t\t// getAttrsFunc is used to get labels and fields of an object.\n107\t\tgetAttrsFunc func(runtime.Object) (labels.Set, fields.Set, bool, error)\n108\t\n109\t\t// cache is used a cyclic buffer - its first element (with the smallest\n110\t\t// resourceVersion) is defined by startIndex, its last element is defined\n111\t\t// by endIndex (if cache is full it will be startIndex + capacity).\n112\t\t// Both startIndex and endIndex can be greater than buffer capacity -\n113\t\t// you should always apply modulo capacity to get an index in cache array.\n114\t\tcache      []watchCacheElement\n115\t\tstartIndex int\n116\t\tendIndex   int\n117\t\n118\t\t// store will effectively support LIST operation from the \"end of cache\n119\t\t// history\" i.e. from the moment just after the newest cached watched event.\n120\t\t// It is necessary to effectively allow clients to start watching at now.\n121\t\t// NOTE: We assume that <store> is thread-safe.\n122\t\tstore cache.Store\n123\t\n124\t\t// ResourceVersion up to which the watchCache is propagated.\n125\t\tresourceVersion uint64\n126\t\n127\t\t// This handler is run at the end of every successful Replace() method.\n128\t\tonReplace func()\n129\t\n130\t\t// This handler is run at the end of every Add/Update/Delete method\n131\t\t// and additionally gets the previous value of the object.\n132\t\tonEvent func(*watchCacheEvent)\n133\t\n134\t\t// for testing timeouts.\n135\t\tclock clock.Clock\n136\t}\n137\t\n138\tfunc newWatchCache(\n139\t\tcapacity int,\n140\t\tkeyFunc func(runtime.Object) (string, error),\n141\t\tgetAttrsFunc func(runtime.Object) (labels.Set, fields.Set, bool, error)) *watchCache {\n142\t\twc := &watchCache{\n143\t\t\tcapacity:        capacity,\n144\t\t\tkeyFunc:         keyFunc,\n145\t\t\tgetAttrsFunc:    getAttrsFunc,\n146\t\t\tcache:           make([]watchCacheElement, capacity),\n147\t\t\tstartIndex:      0,\n148\t\t\tendIndex:        0,\n149\t\t\tstore:           cache.NewStore(storeElementKey),\n150\t\t\tresourceVersion: 0,\n151\t\t\tclock:           clock.RealClock{},\n152\t\t}\n153\t\twc.cond = sync.NewCond(wc.RLocker())\n154\t\treturn wc\n155\t}\n156\t\n157\t// Add takes runtime.Object as an argument.\n158\tfunc (w *watchCache) Add(obj interface{}) error {\n159\t\tobject, resourceVersion, err := objectToVersionedRuntimeObject(obj)\n160\t\tif err != nil {\n161\t\t\treturn err\n162\t\t}\n163\t\tevent := watch.Event{Type: watch.Added, Object: object}\n164\t\n165\t\tf := func(elem *storeElement) error { return w.store.Add(elem) }\n166\t\treturn w.processEvent(event, resourceVersion, f)\n167\t}\n168\t\n169\t// Update takes runtime.Object as an argument.\n170\tfunc (w *watchCache) Update(obj interface{}) error {\n171\t\tobject, resourceVersion, err := objectToVersionedRuntimeObject(obj)\n172\t\tif err != nil {\n173\t\t\treturn err\n174\t\t}\n175\t\tevent := watch.Event{Type: watch.Modified, Object: object}\n176\t\n177\t\tf := func(elem *storeElement) error { return w.store.Update(elem) }\n178\t\treturn w.processEvent(event, resourceVersion, f)\n179\t}\n180\t\n181\t// Delete takes runtime.Object as an argument.\n182\tfunc (w *watchCache) Delete(obj interface{}) error {\n183\t\tobject, resourceVersion, err := objectToVersionedRuntimeObject(obj)\n184\t\tif err != nil {\n185\t\t\treturn err\n186\t\t}\n187\t\tevent := watch.Event{Type: watch.Deleted, Object: object}\n188\t\n189\t\tf := func(elem *storeElement) error { return w.store.Delete(elem) }\n190\t\treturn w.processEvent(event, resourceVersion, f)\n191\t}\n192\t\n193\tfunc objectToVersionedRuntimeObject(obj interface{}) (runtime.Object, uint64, error) {\n194\t\tobject, ok := obj.(runtime.Object)\n195\t\tif !ok {\n196\t\t\treturn nil, 0, fmt.Errorf(\"obj does not implement runtime.Object interface: %v\", obj)\n197\t\t}\n198\t\tmeta, err := meta.Accessor(object)\n199\t\tif err != nil {\n200\t\t\treturn nil, 0, err\n201\t\t}\n202\t\tresourceVersion, err := parseResourceVersion(meta.GetResourceVersion())\n203\t\tif err != nil {\n204\t\t\treturn nil, 0, err\n205\t\t}\n206\t\treturn object, resourceVersion, nil\n207\t}\n208\t\n209\tfunc parseResourceVersion(resourceVersion string) (uint64, error) {\n210\t\tif resourceVersion == \"\" {\n211\t\t\treturn 0, nil\n212\t\t}\n213\t\t// Use bitsize being the size of int on the machine.\n214\t\treturn strconv.ParseUint(resourceVersion, 10, 0)\n215\t}\n216\t\n217\tfunc (w *watchCache) processEvent(event watch.Event, resourceVersion uint64, updateFunc func(*storeElement) error) error {\n218\t\tkey, err := w.keyFunc(event.Object)\n219\t\tif err != nil {\n220\t\t\treturn fmt.Errorf(\"couldn't compute key: %v\", err)\n221\t\t}\n222\t\telem := &storeElement{Key: key, Object: event.Object}\n223\t\n224\t\t// TODO: We should consider moving this lock below after the watchCacheEvent\n225\t\t// is created. In such situation, the only problematic scenario is Replace(\n226\t\t// happening after getting object from store and before acquiring a lock.\n227\t\t// Maybe introduce another lock for this purpose.\n228\t\tw.Lock()\n229\t\tdefer w.Unlock()\n230\t\tprevious, exists, err := w.store.Get(elem)\n231\t\tif err != nil {\n232\t\t\treturn err\n233\t\t}\n234\t\tobjLabels, objFields, objUninitialized, err := w.getAttrsFunc(event.Object)\n235\t\tif err != nil {\n236\t\t\treturn err\n237\t\t}\n238\t\tvar prevObject runtime.Object\n239\t\tvar prevObjLabels labels.Set\n240\t\tvar prevObjFields fields.Set\n241\t\tvar prevObjUninitialized bool\n242\t\tif exists {\n243\t\t\tprevObject = previous.(*storeElement).Object\n244\t\t\tprevObjLabels, prevObjFields, prevObjUninitialized, err = w.getAttrsFunc(prevObject)\n245\t\t\tif err != nil {\n246\t\t\t\treturn err\n247\t\t\t}\n248\t\t}\n249\t\twatchCacheEvent := &watchCacheEvent{\n250\t\t\tType:                 event.Type,\n251\t\t\tObject:               event.Object,\n252\t\t\tObjLabels:            objLabels,\n253\t\t\tObjFields:            objFields,\n254\t\t\tObjUninitialized:     objUninitialized,\n255\t\t\tPrevObject:           prevObject,\n256\t\t\tPrevObjLabels:        prevObjLabels,\n257\t\t\tPrevObjFields:        prevObjFields,\n258\t\t\tPrevObjUninitialized: prevObjUninitialized,\n259\t\t\tKey:                  key,\n260\t\t\tResourceVersion:      resourceVersion,\n261\t\t}\n262\t\tif w.onEvent != nil {\n263\t\t\tw.onEvent(watchCacheEvent)\n264\t\t}\n265\t\tw.updateCache(resourceVersion, watchCacheEvent)\n266\t\tw.resourceVersion = resourceVersion\n267\t\tw.cond.Broadcast()\n268\t\treturn updateFunc(elem)\n269\t}\n270\t\n271\t// Assumes that lock is already held for write.\n272\tfunc (w *watchCache) updateCache(resourceVersion uint64, event *watchCacheEvent) {\n273\t\tif w.endIndex == w.startIndex+w.capacity {\n274\t\t\t// Cache is full - remove the oldest element.\n275\t\t\tw.startIndex++\n276\t\t}\n277\t\tw.cache[w.endIndex%w.capacity] = watchCacheElement{resourceVersion, event}\n278\t\tw.endIndex++\n279\t}\n280\t\n281\t// List returns list of pointers to <storeElement> objects.\n282\tfunc (w *watchCache) List() []interface{} {\n283\t\treturn w.store.List()\n284\t}\n285\t\n286\t// waitUntilFreshAndBlock waits until cache is at least as fresh as given <resourceVersion>.\n287\t// NOTE: This function acquired lock and doesn't release it.\n288\t// You HAVE TO explicitly call w.RUnlock() after this function.\n289\tfunc (w *watchCache) waitUntilFreshAndBlock(resourceVersion uint64, trace *utiltrace.Trace) error {\n290\t\tstartTime := w.clock.Now()\n291\t\tgo func() {\n292\t\t\t// Wake us up when the time limit has expired.  The docs\n293\t\t\t// promise that time.After (well, NewTimer, which it calls)\n294\t\t\t// will wait *at least* the duration given. Since this go\n295\t\t\t// routine starts sometime after we record the start time, and\n296\t\t\t// it will wake up the loop below sometime after the broadcast,\n297\t\t\t// we don't need to worry about waking it up before the time\n298\t\t\t// has expired accidentally.\n299\t\t\t<-w.clock.After(blockTimeout)\n300\t\t\tw.cond.Broadcast()\n301\t\t}()\n302\t\n303\t\tw.RLock()\n304\t\tif trace != nil {\n305\t\t\ttrace.Step(\"watchCache locked acquired\")\n306\t\t}\n307\t\tfor w.resourceVersion < resourceVersion {\n308\t\t\tif w.clock.Since(startTime) >= blockTimeout {\n309\t\t\t\t// Timeout with retry after 1 second.\n310\t\t\t\treturn errors.NewTimeoutError(fmt.Sprintf(\"Too large resource version: %v, current: %v\", resourceVersion, w.resourceVersion), 1)\n311\t\t\t}\n312\t\t\tw.cond.Wait()\n313\t\t}\n314\t\tif trace != nil {\n315\t\t\ttrace.Step(\"watchCache fresh enough\")\n316\t\t}\n317\t\treturn nil\n318\t}\n319\t\n320\t// WaitUntilFreshAndList returns list of pointers to <storeElement> objects.\n321\tfunc (w *watchCache) WaitUntilFreshAndList(resourceVersion uint64, trace *utiltrace.Trace) ([]interface{}, uint64, error) {\n322\t\terr := w.waitUntilFreshAndBlock(resourceVersion, trace)\n323\t\tdefer w.RUnlock()\n324\t\tif err != nil {\n325\t\t\treturn nil, 0, err\n326\t\t}\n327\t\treturn w.store.List(), w.resourceVersion, nil\n328\t}\n329\t\n330\t// WaitUntilFreshAndGet returns a pointers to <storeElement> object.\n331\tfunc (w *watchCache) WaitUntilFreshAndGet(resourceVersion uint64, key string, trace *utiltrace.Trace) (interface{}, bool, uint64, error) {\n332\t\terr := w.waitUntilFreshAndBlock(resourceVersion, trace)\n333\t\tdefer w.RUnlock()\n334\t\tif err != nil {\n335\t\t\treturn nil, false, 0, err\n336\t\t}\n337\t\tvalue, exists, err := w.store.GetByKey(key)\n338\t\treturn value, exists, w.resourceVersion, err\n339\t}\n340\t\n341\tfunc (w *watchCache) ListKeys() []string {\n342\t\treturn w.store.ListKeys()\n343\t}\n344\t\n345\t// Get takes runtime.Object as a parameter. However, it returns\n346\t// pointer to <storeElement>.\n347\tfunc (w *watchCache) Get(obj interface{}) (interface{}, bool, error) {\n348\t\tobject, ok := obj.(runtime.Object)\n349\t\tif !ok {\n350\t\t\treturn nil, false, fmt.Errorf(\"obj does not implement runtime.Object interface: %v\", obj)\n351\t\t}\n352\t\tkey, err := w.keyFunc(object)\n353\t\tif err != nil {\n354\t\t\treturn nil, false, fmt.Errorf(\"couldn't compute key: %v\", err)\n355\t\t}\n356\t\n357\t\treturn w.store.Get(&storeElement{Key: key, Object: object})\n358\t}\n359\t\n360\t// GetByKey returns pointer to <storeElement>.\n361\tfunc (w *watchCache) GetByKey(key string) (interface{}, bool, error) {\n362\t\treturn w.store.GetByKey(key)\n363\t}\n364\t\n365\t// Replace takes slice of runtime.Object as a paramater.\n366\tfunc (w *watchCache) Replace(objs []interface{}, resourceVersion string) error {\n367\t\tversion, err := parseResourceVersion(resourceVersion)\n368\t\tif err != nil {\n369\t\t\treturn err\n370\t\t}\n371\t\n372\t\ttoReplace := make([]interface{}, 0, len(objs))\n373\t\tfor _, obj := range objs {\n374\t\t\tobject, ok := obj.(runtime.Object)\n375\t\t\tif !ok {\n376\t\t\t\treturn fmt.Errorf(\"didn't get runtime.Object for replace: %#v\", obj)\n377\t\t\t}\n378\t\t\tkey, err := w.keyFunc(object)\n379\t\t\tif err != nil {\n380\t\t\t\treturn fmt.Errorf(\"couldn't compute key: %v\", err)\n381\t\t\t}\n382\t\t\ttoReplace = append(toReplace, &storeElement{Key: key, Object: object})\n383\t\t}\n384\t\n385\t\tw.Lock()\n386\t\tdefer w.Unlock()\n387\t\n388\t\tw.startIndex = 0\n389\t\tw.endIndex = 0\n390\t\tif err := w.store.Replace(toReplace, resourceVersion); err != nil {\n391\t\t\treturn err\n392\t\t}\n393\t\tw.resourceVersion = version\n394\t\tif w.onReplace != nil {\n395\t\t\tw.onReplace()\n396\t\t}\n397\t\tw.cond.Broadcast()\n398\t\treturn nil\n399\t}\n400\t\n401\tfunc (w *watchCache) SetOnReplace(onReplace func()) {\n402\t\tw.Lock()\n403\t\tdefer w.Unlock()\n404\t\tw.onReplace = onReplace\n405\t}\n406\t\n407\tfunc (w *watchCache) SetOnEvent(onEvent func(*watchCacheEvent)) {\n408\t\tw.Lock()\n409\t\tdefer w.Unlock()\n410\t\tw.onEvent = onEvent\n411\t}\n412\t\n413\tfunc (w *watchCache) GetAllEventsSinceThreadUnsafe(resourceVersion uint64) ([]*watchCacheEvent, error) {\n414\t\tsize := w.endIndex - w.startIndex\n415\t\t// if we have no watch events in our cache, the oldest one we can successfully deliver to a watcher\n416\t\t// is the *next* event we'll receive, which will be at least one greater than our current resourceVersion\n417\t\toldest := w.resourceVersion + 1\n418\t\tif size > 0 {\n419\t\t\toldest = w.cache[w.startIndex%w.capacity].resourceVersion\n420\t\t}\n421\t\tif resourceVersion == 0 {\n422\t\t\t// resourceVersion = 0 means that we don't require any specific starting point\n423\t\t\t// and we would like to start watching from ~now.\n424\t\t\t// However, to keep backward compatibility, we additionally need to return the\n425\t\t\t// current state and only then start watching from that point.\n426\t\t\t//\n427\t\t\t// TODO: In v2 api, we should stop returning the current state - #13969.\n428\t\t\tallItems := w.store.List()\n429\t\t\tresult := make([]*watchCacheEvent, len(allItems))\n430\t\t\tfor i, item := range allItems {\n431\t\t\t\telem, ok := item.(*storeElement)\n432\t\t\t\tif !ok {\n433\t\t\t\t\treturn nil, fmt.Errorf(\"not a storeElement: %v\", elem)\n434\t\t\t\t}\n435\t\t\t\tobjLabels, objFields, objUninitialized, err := w.getAttrsFunc(elem.Object)\n436\t\t\t\tif err != nil {\n437\t\t\t\t\treturn nil, err\n438\t\t\t\t}\n439\t\t\t\tresult[i] = &watchCacheEvent{\n440\t\t\t\t\tType:             watch.Added,\n441\t\t\t\t\tObject:           elem.Object,\n442\t\t\t\t\tObjLabels:        objLabels,\n443\t\t\t\t\tObjFields:        objFields,\n444\t\t\t\t\tObjUninitialized: objUninitialized,\n445\t\t\t\t\tKey:              elem.Key,\n446\t\t\t\t\tResourceVersion:  w.resourceVersion,\n447\t\t\t\t}\n448\t\t\t}\n449\t\t\treturn result, nil\n450\t\t}\n451\t\tif resourceVersion < oldest-1 {\n452\t\t\treturn nil, errors.NewGone(fmt.Sprintf(\"too old resource version: %d (%d)\", resourceVersion, oldest-1))\n453\t\t}\n454\t\n455\t\t// Binary search the smallest index at which resourceVersion is greater than the given one.\n456\t\tf := func(i int) bool {\n457\t\t\treturn w.cache[(w.startIndex+i)%w.capacity].resourceVersion > resourceVersion\n458\t\t}\n459\t\tfirst := sort.Search(size, f)\n460\t\tresult := make([]*watchCacheEvent, size-first)\n461\t\tfor i := 0; i < size-first; i++ {\n462\t\t\tresult[i] = w.cache[(w.startIndex+first+i)%w.capacity].watchCacheEvent\n463\t\t}\n464\t\treturn result, nil\n465\t}\n466\t\n467\tfunc (w *watchCache) GetAllEventsSince(resourceVersion uint64) ([]*watchCacheEvent, error) {\n468\t\tw.RLock()\n469\t\tdefer w.RUnlock()\n470\t\treturn w.GetAllEventsSinceThreadUnsafe(resourceVersion)\n471\t}\n472\t\n473\tfunc (w *watchCache) Resync() error {\n474\t\t// Nothing to do\n475\t\treturn nil\n476\t}\n477\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01Beb4TbnUESNeUmKMEDYctf","session_id":"e8a2b282-9c85-4d7e-a765-e2618887422f","uuid":"1fdc27f6-008b-40a1-8dda-9ae4ec7f6e04","timestamp":"2026-04-01T00:38:23.331Z"}
