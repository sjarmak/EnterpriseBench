r\n56\t\n57\t\t// The Cache will be caching objects of a given Type and assumes that they\n58\t\t// are all stored under ResourcePrefix directory in the underlying database.\n59\t\tType           interface{}\n60\t\tResourcePrefix string\n61\t\n62\t\t// KeyFunc is used to get a key in the underlying storage for a given object.\n63\t\tKeyFunc func(runtime.Object) (string, error)\n64\t\n65\t\t// GetAttrsFunc is used to get object labels, fields, and the uninitialized bool\n66\t\tGetAttrsFunc func(runtime.Object) (label labels.Set, field fields.Set, uninitialized bool, err error)\n67\t\n68\t\t// TriggerPublisherFunc is used for optimizing amount of watchers that\n69\t\t// needs to process an incoming event.\n70\t\tTriggerPublisherFunc TriggerPublisherFunc\n71\t\n72\t\t// NewList is a function that creates new empty object storing a list of\n73\t\t// objects of type Type.\n74\t\tNewListFunc func() runtime.Object\n75\t\n76\t\tCodec runtime.Codec\n77\t}\n78\t\n79\ttype watchersMap map[int]*cacheWatcher\n80\t\n81\tfunc (wm watchersMap) addWatcher(w *cacheWatcher, number int) {\n82\t\twm[number] = w\n83\t}\n84\t\n85\tfunc (wm watchersMap) deleteWatcher(number int) {\n86\t\tdelete(wm, number)\n87\t}\n88\t\n89\tfunc (wm watchersMap) terminateAll() {\n90\t\tfor key, watcher := range wm {\n91\t\t\tdelete(wm, key)\n92\t\t\twatcher.stop()\n93\t\t}\n94\t}\n95\t\n96\ttype indexedWatchers struct {\n97\t\tallWatchers   watchersMap\n98\t\tvalueWatchers map[string]watchersMap\n99\t}\n100\t\n101\tfunc (i *indexedWatchers) addWatcher(w *cacheWatcher, number int, value string, supported bool) {\n102\t\tif supported {\n103\t\t\tif _, ok := i.valueWatchers[value]; !ok {\n104\t\t\t\ti.valueWatchers[value] = watchersMap{}\n105\t\t\t}\n106\t\t\ti.valueWatchers[value].addWatcher(w, number)\n107\t\t} else {\n108\t\t\ti.allWatchers.addWatcher(w, number)\n109\t\t}\n110\t}\n111\t\n112\tfunc (i *indexedWatchers) deleteWatcher(number int, value string, supported bool) {\n113\t\tif supported {\n114\t\t