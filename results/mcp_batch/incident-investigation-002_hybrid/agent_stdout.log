r\n56\t\n57\t\t// The Cache will be caching objects of a given Type and assumes that they\n58\t\t// are all stored under ResourcePrefix directory in the underlying database.\n59\t\tType           interface{}\n60\t\tResourcePrefix string\n61\t\n62\t\t// KeyFunc is used to get a key in the underlying storage for a given object.\n63\t\tKeyFunc func(runtime.Object) (string, error)\n64\t\n65\t\t// GetAttrsFunc is used to get object labels, fields, and the uninitialized bool\n66\t\tGetAttrsFunc func(runtime.Object) (label labels.Set, field fields.Set, uninitialized bool, err error)\n67\t\n68\t\t// TriggerPublisherFunc is used for optimizing amount of watchers that\n69\t\t// needs to process an incoming event.\n70\t\tTriggerPublisherFunc TriggerPublisherFunc\n71\t\n72\t\t// NewList is a function that creates new empty object storing a list of\n73\t\t// objects of type Type.\n74\t\tNewListFunc func() runtime.Object\n75\t\n76\t\tCodec runtime.Codec\n77\t}\n78\t\n79\ttype watchersMap map[int]*cacheWatcher\n80\t\n81\tfunc (wm watchersMap) addWatcher(w *cacheWatcher, number int) {\n82\t\twm[number] = w\n83\t}\n84\t\n85\tfunc (wm watchersMap) deleteWatcher(number int) {\n86\t\tdelete(wm, number)\n87\t}\n88\t\n89\tfunc (wm watchersMap) terminateAll() {\n90\t\tfor key, watcher := range wm {\n91\t\t\tdelete(wm, key)\n92\t\t\twatcher.stop()\n93\t\t}\n94\t}\n95\t\n96\ttype indexedWatchers struct {\n97\t\tallWatchers   watchersMap\n98\t\tvalueWatchers map[string]watchersMap\n99\t}\n100\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01N9knQb5DeexNU4bTXPFV3j","session_id":"9f99c861-4307-4141-b082-04ddb8e66e58","uuid":"260986ee-3839-4a1c-aeb4-9ad2929e3e21","time