{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FcPexeSB8atqKyUUyDjisg","type":"tool_result","content":"1\t/*\n2\tCopyright 2016 The Kubernetes Authors.\n3\t\n4\tLicensed under the Apache License, Version 2.0 (the \"License\");\n5\tyou may not use this file except in compliance with the License.\n6\tYou may obtain a copy of the License at\n7\t\n8\t    http://www.apache.org/licenses/LICENSE-2.0\n9\t\n10\tUnless required by applicable law or agreed to in writing, software\n11\tdistributed under the License is distributed on an \"AS IS\" BASIS,\n12\tWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13\tSee the License for the specific language governing permissions and\n14\tlimitations under the License.\n15\t*/\n16\t\n17\tpackage etcd3\n18\t\n19\timport (\n20\t\t\"errors\"\n21\t\t\"fmt\"\n22\t\t\"os\"\n23\t\t\"strconv\"\n24\t\t\"strings\"\n25\t\t\"sync\"\n26\t\n27\t\tapierrs \"k8s.io/apimachinery/pkg/api/errors\"\n28\t\t\"k8s.io/apimachinery/pkg/runtime\"\n29\t\t\"k8s.io/apimachinery/pkg/watch\"\n30\t\t\"k8s.io/apiserver/pkg/storage\"\n31\t\t\"k8s.io/apiserver/pkg/storage/value\"\n32\t\n33\t\t\"github.com/coreos/etcd/clientv3\"\n34\t\t\"github.com/golang/glog\"\n35\t\t\"golang.org/x/net/context\"\n36\t)\n37\t\n38\tconst (\n39\t\t// We have set a buffer in order to reduce times of context switches.\n40\t\tincomingBufSize = 100\n41\t\toutgoingBufSize = 100\n42\t)\n43\t\n44\t// fatalOnDecodeError is used during testing to panic the server if watcher encounters a decoding error\n45\tvar fatalOnDecodeError = false\n46\t\n47\t// errTestingDecode is the only error that testingDeferOnDecodeError catches during a panic\n48\tvar errTestingDecode = errors.New(\"sentinel error only used during testing to indicate watch decoding error\")\n49\t\n50\t// testingDeferOnDecodeError is used during testing to recover from a panic caused by errTestingDecode, all other values continue to panic\n51\tfunc testingDeferOnDecodeError() {\n52\t\tif r := recover(); r != nil && r != errTestingDecode {\n53\t\t\tpanic(r)\n54\t\t}\n55\t}\n56\t\n57\tfunc init() {\n58\t\t// check to see if we are running in a test environment\n59\t\tfatalOnDecodeError, _ = strconv.ParseBool(os.Getenv(\"KUBE_PANIC_WATCH_DECODE_ERROR\"))\n60\t}\n61\t\n62\ttype watcher struct {\n63\t\tclient      *clientv3.Client\n64\t\tcodec       runtime.Codec\n65\t\tversioner   storage.Versioner\n66\t\ttransformer value.Transformer\n67\t}\n68\t\n69\t// watchChan implements watch.Interface.\n70\ttype watchChan struct {\n71\t\twatcher           *watcher\n72\t\tkey               string\n73\t\tinitialRev        int64\n74\t\trecursive         bool\n75\t\tinternalFilter    storage.FilterFunc\n76\t\tctx               context.Context\n77\t\tcancel            context.CancelFunc\n78\t\tincomingEventChan chan *event\n79\t\tresultChan        chan watch.Event\n80\t\terrChan           chan error\n81\t}\n82\t\n83\tfunc newWatcher(client *clientv3.Client, codec runtime.Codec, versioner storage.Versioner, transformer value.Transformer) *watcher {\n84\t\treturn &watcher{\n85\t\t\tclient:      client,\n86\t\t\tcodec:       codec,\n87\t\t\tversioner:   versioner,\n88\t\t\ttransformer: transformer,\n89\t\t}\n90\t}\n91\t\n92\t// Watch watches on a key and returns a watch.Interface that transfers relevant notifications.\n93\t// If rev is zero, it will return the existing object(s) and then start watching from\n94\t// the maximum revision+1 from returned objects.\n95\t// If rev is non-zero, it will watch events happened after given revision.\n96\t// If recursive is false, it watches on given key.\n97\t// If recursive is true, it watches any children and directories under the key, excluding the root key itself.\n98\t// pred must be non-nil. Only if pred matches the change, it will be returned.\n99\tfunc (w *watcher) Watch(ctx context.Context, key string, rev int64, recursive bool, pred storage.SelectionPredicate) (watch.Interface, error) {\n100\t\tif recursive && !strings.HasSuffix(key, \"/\") {\n101\t\t\tkey += \"/\"\n102\t\t}\n103\t\twc := w.createWatchChan(ctx, key, rev, recursive, pred)\n104\t\tgo wc.run()\n105\t\treturn wc, nil\n106\t}\n107\t\n108\tfunc (w *watcher) createWatchChan(ctx context.Context, key string, rev int64, recursive bool, pred storage.SelectionPredicate) *watchChan {\n109\t\twc := &watchChan{\n110\t\t\twatcher:           w,\n111\t\t\tkey:               key,\n112\t\t\tinitialRev:        rev,\n113\t\t\trecursive:         recursive,\n114\t\t\tinternalFilter:    storage.SimpleFilter(pred),\n115\t\t\tincomingEventChan: make(chan *event, incomingBufSize),\n116\t\t\tresultChan:        make(chan watch.Event, outgoingBufSize),\n117\t\t\terrChan:           make(chan error, 1),\n118\t\t}\n119\t\tif pred.Empty() {\n120\t\t\t// The filter doesn't filter out any object.\n121\t\t\twc.internalFilter = nil\n122\t\t}\n123\t\twc.ctx, wc.cancel = context.WithCancel(ctx)\n124\t\treturn wc\n125\t}\n126\t\n127\tfunc (wc *watchChan) run() {\n128\t\twatchClosedCh := make(chan struct{})\n129\t\tgo wc.startWatching(watchClosedCh)\n130\t\n131\t\tvar resultChanWG sync.WaitGroup\n132\t\tresultChanWG.Add(1)\n133\t\tgo wc.processEvent(&resultChanWG)\n134\t\n135\t\tselect {\n136\t\tcase err := <-wc.errChan:\n137\t\t\tif err == context.Canceled {\n138\t\t\t\tbreak\n139\t\t\t}\n140\t\t\terrResult := transformErrorToEvent(err)\n141\t\t\tif errResult != nil {\n142\t\t\t\t// error result is guaranteed to be received by user before closing ResultChan.\n143\t\t\t\tselect {\n144\t\t\t\tcase wc.resultChan <- *errResult:\n145\t\t\t\tcase <-wc.ctx.Done(): // user has given up all results\n146\t\t\t\t}\n147\t\t\t}\n148\t\tcase <-watchClosedCh:\n149\t\tcase <-wc.ctx.Done(): // user cancel\n150\t\t}\n151\t\n152\t\t// We use wc.ctx to reap all goroutines. Under whatever condition, we should stop them all.\n153\t\t// It's fine to double cancel.\n154\t\twc.cancel()\n155\t\n156\t\t// we need to wait until resultChan wouldn't be used anymore\n157\t\tresultChanWG.Wait()\n158\t\tclose(wc.resultChan)\n159\t}\n160\t\n161\tfunc (wc *watchChan) Stop() {\n162\t\twc.cancel()\n163\t}\n164\t\n165\tfunc (wc *watchChan) ResultChan() <-chan watch.Event {\n166\t\treturn wc.resultChan\n167\t}\n168\t\n169\t// sync tries to retrieve existing data and send them to process.\n170\t// The revision to watch will be set to the revision in response.\n171\t// All events sent will have isCreated=true\n172\tfunc (wc *watchChan) sync() error {\n173\t\topts := []clientv3.OpOption{}\n174\t\tif wc.recursive {\n175\t\t\topts = append(opts, clientv3.WithPrefix())\n176\t\t}\n177\t\tgetResp, err := wc.watcher.client.Get(wc.ctx, wc.key, opts...)\n178\t\tif err != nil {\n179\t\t\treturn err\n180\t\t}\n181\t\twc.initialRev = getResp.Header.Revision\n182\t\tfor _, kv := range getResp.Kvs {\n183\t\t\twc.sendEvent(parseKV(kv))\n184\t\t}\n185\t\treturn nil\n186\t}\n187\t\n188\t// startWatching does:\n189\t// - get current objects if initialRev=0; set initialRev to current rev\n190\t// - watch on given key and send events to process.\n191\tfunc (wc *watchChan) startWatching(watchClosedCh chan struct{}) {\n192\t\tif wc.initialRev == 0 {\n193\t\t\tif err := wc.sync(); err != nil {\n194\t\t\t\tglog.Errorf(\"failed to sync with latest state: %v\", err)\n195\t\t\t\twc.sendError(err)\n196\t\t\t\treturn\n197\t\t\t}\n198\t\t}\n199\t\topts := []clientv3.OpOption{clientv3.WithRev(wc.initialRev + 1), clientv3.WithPrevKV()}\n200\t\tif wc.recursive {\n201\t\t\topts = append(opts, clientv3.WithPrefix())\n202\t\t}\n203\t\twch := wc.watcher.client.Watch(wc.ctx, wc.key, opts...)\n204\t\tfor wres := range wch {\n205\t\t\tif wres.Err() != nil {\n206\t\t\t\terr := wres.Err()\n207\t\t\t\t// If there is an error on server (e.g. compaction), the channel will return it before closed.\n208\t\t\t\tglog.Errorf(\"watch chan error: %v\", err)\n209\t\t\t\twc.sendError(err)\n210\t\t\t\treturn\n211\t\t\t}\n212\t\t\tfor _, e := range wres.Events {\n213\t\t\t\twc.sendEvent(parseEvent(e))\n214\t\t\t}\n215\t\t}\n216\t\t// When we come to this point, it's only possible that client side ends the watch.\n217\t\t// e.g. cancel the context, close the client.\n218\t\t// If this watch chan is broken and context isn't cancelled, other goroutines will still hang.\n219\t\t// We should notify the main thread that this goroutine has exited.\n220\t\tclose(watchClosedCh)\n221\t}\n222\t\n223\t// processEvent processes events from etcd watcher and sends results to resultChan.\n224\tfunc (wc *watchChan) processEvent(wg *sync.WaitGroup) {\n225\t\tdefer wg.Done()\n226\t\n227\t\tfor {\n228\t\t\tselect {\n229\t\t\tcase e := <-wc.incomingEventChan:\n230\t\t\t\tres := wc.transform(e)\n231\t\t\t\tif res == nil {\n232\t\t\t\t\tcontinue\n233\t\t\t\t}\n234\t\t\t\tif len(wc.resultChan) == outgoingBufSize {\n235\t\t\t\t\tglog.Warningf(\"Fast watcher, slow processing. Number of buffered events: %d.\"+\n236\t\t\t\t\t\t\"Probably caused by slow dispatching events to watchers\", outgoingBufSize)\n237\t\t\t\t}\n238\t\t\t\t// If user couldn't receive results fast enough, we also block incoming events from watcher.\n239\t\t\t\t// Because storing events in local will cause more memory usage.\n240\t\t\t\t// The worst case would be closing the fast watcher.\n241\t\t\t\tselect {\n242\t\t\t\tcase wc.resultChan <- *res:\n243\t\t\t\tcase <-wc.ctx.Done():\n244\t\t\t\t\treturn\n245\t\t\t\t}\n246\t\t\tcase <-wc.ctx.Done():\n247\t\t\t\treturn\n248\t\t\t}\n249\t\t}\n250\t}\n251\t\n252\tfunc (wc *watchChan) filter(obj runtime.Object) bool {\n253\t\tif wc.internalFilter == nil {\n254\t\t\treturn true\n255\t\t}\n256\t\treturn wc.internalFilter(obj)\n257\t}\n258\t\n259\tfunc (wc *watchChan) acceptAll() bool {\n260\t\treturn wc.internalFilter == nil\n261\t}\n262\t\n263\t// transform transforms an event into a result for user if not filtered.\n264\tfunc (wc *watchChan) transform(e *event) (res *watch.Event) {\n265\t\tcurObj, oldObj, err := wc.prepareObjs(e)\n266\t\tif err != nil {\n267\t\t\tglog.Errorf(\"failed to prepare current and previous objects: %v\", err)\n268\t\t\twc.sendError(err)\n269\t\t\treturn nil\n270\t\t}\n271\t\n272\t\tswitch {\n273\t\tcase e.isDeleted:\n274\t\t\tif !wc.filter(oldObj) {\n275\t\t\t\treturn nil\n276\t\t\t}\n277\t\t\tres = &watch.Event{\n278\t\t\t\tType:   watch.Deleted,\n279\t\t\t\tObject: oldObj,\n280\t\t\t}\n281\t\tcase e.isCreated:\n282\t\t\tif !wc.filter(curObj) {\n283\t\t\t\treturn nil\n284\t\t\t}\n285\t\t\tres = &watch.Event{\n286\t\t\t\tType:   watch.Added,\n287\t\t\t\tObject: curObj,\n288\t\t\t}\n289\t\tdefault:\n290\t\t\tif wc.acceptAll() {\n291\t\t\t\tres = &watch.Event{\n292\t\t\t\t\tType:   watch.Modified,\n293\t\t\t\t\tObject: curObj,\n294\t\t\t\t}\n295\t\t\t\treturn res\n296\t\t\t}\n297\t\t\tcurObjPasses := wc.filter(curObj)\n298\t\t\toldObjPasses := wc.filter(oldObj)\n299\t\t\tswitch {\n300\t\t\tcase curObjPasses && oldObjPasses:\n301\t\t\t\tres = &watch.Event{\n302\t\t\t\t\tType:   watch.Modified,\n303\t\t\t\t\tObject: curObj,\n304\t\t\t\t}\n305\t\t\tcase curObjPasses && !oldObjPasses:\n306\t\t\t\tres = &watch.Event{\n307\t\t\t\t\tType:   watch.Added,\n308\t\t\t\t\tObject: curObj,\n309\t\t\t\t}\n310\t\t\tcase !curObjPasses && oldObjPasses:\n311\t\t\t\tres = &watch.Event{\n312\t\t\t\t\tType:   watch.Deleted,\n313\t\t\t\t\tObject: oldObj,\n314\t\t\t\t}\n315\t\t\t}\n316\t\t}\n317\t\treturn res\n318\t}\n319\t\n320\tfunc transformErrorToEvent(err error) *watch.Event {\n321\t\terr = interpretWatchError(err)\n322\t\tif _, ok := err.(apierrs.APIStatus); !ok {\n323\t\t\terr = apierrs.NewInternalError(err)\n324\t\t}\n325\t\tstatus := err.(apierrs.APIStatus).Status()\n326\t\treturn &watch.Event{\n327\t\t\tType:   watch.Error,\n328\t\t\tObject: &status,\n329\t\t}\n330\t}\n331\t\n332\tfunc (wc *watchChan) sendError(err error) {\n333\t\tselect {\n334\t\tcase wc.errChan <- err:\n335\t\tcase <-wc.ctx.Done():\n336\t\t}\n337\t}\n338\t\n339\tfunc (wc *watchChan) sendEvent(e *event) {\n340\t\tif len(wc.incomingEventChan) == incomingBufSize {\n341\t\t\tglog.Warningf(\"Fast watcher, slow processing. Number of buffered events: %d.\"+\n342\t\t\t\t\"Probably caused by slow decoding, user not receiving fast, or other processing logic\",\n343\t\t\t\tincomingBufSize)\n344\t\t}\n345\t\tselect {\n346\t\tcase wc.incomingEventChan <- e:\n347\t\tcase <-wc.ctx.Done():\n348\t\t}\n349\t}\n350\t\n351\tfunc (wc *watchChan) prepareObjs(e *event) (curObj runtime.Object, oldObj runtime.Object, err error) {\n352\t\tif !e.isDeleted {\n353\t\t\tdata, _, err := wc.watcher.transformer.TransformFromStorage(e.value, authenticatedDataString(e.key))\n354\t\t\tif err != nil {\n355\t\t\t\treturn nil, nil, err\n356\t\t\t}\n357\t\t\tcurObj, err = decodeObj(wc.watcher.codec, wc.watcher.versioner, data, e.rev)\n358\t\t\tif err != nil {\n359\t\t\t\treturn nil, nil, err\n360\t\t\t}\n361\t\t}\n362\t\t// We need to decode prevValue, only if this is deletion event or\n363\t\t// the underlying filter doesn't accept all objects (otherwise we\n364\t\t// know that the filter for previous object will return true and\n365\t\t// we need the object only to compute whether it was filtered out\n366\t\t// before).\n367\t\tif len(e.prevValue) > 0 && (e.isDeleted || !wc.acceptAll()) {\n368\t\t\tdata, _, err := wc.watcher.transformer.TransformFromStorage(e.prevValue, authenticatedDataString(e.key))\n369\t\t\tif err != nil {\n370\t\t\t\treturn nil, nil, err\n371\t\t\t}\n372\t\t\t// Note that this sends the *old* object with the etcd revision for the time at\n373\t\t\t// which it gets deleted.\n374\t\t\toldObj, err = decodeObj(wc.watcher.codec, wc.watcher.versioner, data, e.rev)\n375\t\t\tif err != nil {\n376\t\t\t\treturn nil, nil, err\n377\t\t\t}\n378\t\t}\n379\t\treturn curObj, oldObj, nil\n380\t}\n381\t\n382\tfunc decodeObj(codec runtime.Codec, versioner storage.Versioner, data []byte, rev int64) (_ runtime.Object, err error) {\n383\t\tobj, err := runtime.Decode(codec, []byte(data))\n384\t\tif err != nil {\n385\t\t\tif fatalOnDecodeError {\n386\t\t\t\t// catch watch decode error iff we caused it on\n387\t\t\t\t// purpose during a unit test\n388\t\t\t\tdefer testingDeferOnDecodeError()\n389\t\t\t\t// we are running in a test environment and thus an\n390\t\t\t\t// error here is due to a coder mistake if the defer\n391\t\t\t\t// does not catch it\n392\t\t\t\tpanic(err)\n393\t\t\t}\n394\t\t\treturn nil, err\n395\t\t}\n396\t\t// ensure resource version is set on the object we load from etcd\n397\t\tif err := versioner.UpdateObject(obj, uint64(rev)); err != nil {\n398\t\t\treturn nil, fmt.Errorf(\"failure to version api object (%d) %#v: %v\", rev, obj, err)\n399\t\t}\n400\t\treturn obj, nil\n401\t}\n402\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01N9knQb5DeexNU4bTXPFV3j","session_id":"9f99c861-4307-4141-b082-04ddb8e66e58","uuid":"872206f3-5bf8-4661-bc29-da466fb8d6b6","timestamp":"2026-03-31T21:46:39.700Z"}
