sions can be forged). SESSION_COOKIE_SECURE=False in production sends session cookies over plain HTTP, enabling session hijacking.\"\n  }\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1723,"cache_read_input_tokens":29767,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1723},"output_tokens":18,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"780e4baa-3aa8-4b0d-9a7b-e4e22ccb96cd","uuid":"4544edc4-3cd5-498e-9d12-57705fafdcea"}
