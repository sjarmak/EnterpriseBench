{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PkMQZxFjyH8dWXwyacmQXR","type":"tool_result","content":"{\"text\":\"URL: https://demo.sourcegraph.com/github.com/sg-evals/etcd-io-etcd@17dae73b287c31f5cf3a70e48cf38a113a14f12a/-/blob/client/v3/retry_interceptor.go%3FL60-130\\n60: \\t\\t\\tif lastErr == nil {\\n61: \\t\\t\\t\\treturn nil\\n62: \\t\\t\\t}\\n63: \\t\\t\\tc.GetLogger().Warn(\\n64: \\t\\t\\t\\t\\\"retrying of unary invoker failed\\\",\\n65: \\t\\t\\t\\tzap.String(\\\"target\\\", cc.Target()),\\n66: \\t\\t\\t\\tzap.Uint(\\\"attempt\\\", attempt),\\n67: \\t\\t\\t\\tzap.Error(lastErr),\\n68: \\t\\t\\t)\\n69: \\t\\t\\tif isContextError(lastErr) {\\n70: \\t\\t\\t\\tif ctx.Err() != nil {\\n71: \\t\\t\\t\\t\\t// its the context deadline or cancellation.\\n72: \\t\\t\\t\\t\\treturn lastErr\\n73: \\t\\t\\t\\t}\\n74: \\t\\t\\t\\t// its the callCtx deadline or cancellation, in which case try again.\\n75: \\t\\t\\t\\tcontinue\\n76: \\t\\t\\t}\\n77: \\t\\t\\tif c.shouldRefreshToken(lastErr, callOpts) {\\n78: \\t\\t\\t\\tgterr := c.refreshToken(ctx)\\n79: \\t\\t\\t\\tif gterr != nil {\\n80: \\t\\t\\t\\t\\tc.GetLogger().Warn(\\n81: \\t\\t\\t\\t\\t\\t\\\"retrying of unary invoker failed to fetch new auth token\\\",\\n82: \\t\\t\\t\\t\\t\\tzap.String(\\\"target\\\", cc.Target()),\\n83: \\t\\t\\t\\t\\t\\tzap.Error(gterr),\\n84: \\t\\t\\t\\t\\t)\\n85: \\t\\t\\t\\t\\treturn gterr // lastErr must be invalid auth token\\n86: \\t\\t\\t\\t}\\n87: \\t\\t\\t\\tcontinue\\n88: \\t\\t\\t}\\n89: \\t\\t\\tif !isSafeRetry(c, lastErr, callOpts) {\\n90: \\t\\t\\t\\treturn lastErr\\n91: \\t\\t\\t}\\n92: \\t\\t}\\n93: \\t\\treturn lastErr\\n94: \\t}\\n95: }\\n96: \\n97: // streamClientInterceptor returns a new retrying stream client interceptor for server side streaming calls.\\n98: //\\n99: // The default configuration of the interceptor is to not retry *at all*. This behaviour can be\\n100: // changed through options (e.g. WithMax) on creation of the interceptor or on call (through grpc.CallOptions).\\n101: //\\n102: // Retry logic is available *only for ServerStreams*, i.e. 1:n streams, as the internal logic needs\\n103: // to buffer the messages sent by the client. If retry is enabled on any other streams (ClientStreams,\\n104: // BidiStreams), the retry interceptor will fail the call.\\n105: func (c *Client) streamClientInterceptor(optFuncs ...retryOption) grpc.StreamClientInterceptor {\\n106: \\tintOpts := reuseOrNewWithCallOptions(defaultOptions, optFuncs)\\n107: \\treturn func(ctx context.Context, desc *grpc.StreamDesc, cc *grpc.ClientConn, method string, streamer grpc.Streamer, opts ...grpc.CallOption) (grpc.ClientStream, error) {\\n108: \\t\\tctx = withVersion(ctx)\\n109: \\t\\t// getToken automatically\\n110: \\t\\t// TODO(cfc4n): keep this code block, remove codes about getToken in client.go after pr #12165 merged.\\n111: \\t\\tif c.authTokenBundle != nil {\\n112: \\t\\t\\t// equal to c.Username != \\\"\\\" && c.Password != \\\"\\\"\\n113: \\t\\t\\terr := c.getToken(ctx)\\n114: \\t\\t\\tif err != nil && rpctypes.Error(err) != rpctypes.ErrAuthNotEnabled {\\n115: \\t\\t\\t\\tc.GetLogger().Error(\\\"clientv3/retry_interceptor: getToken failed\\\", zap.Error(err))\\n116: \\t\\t\\t\\treturn nil, err\\n117: \\t\\t\\t}\\n118: \\t\\t}\\n119: \\t\\tgrpcOpts, retryOpts := filterCallOptions(opts)\\n120: \\t\\tcallOpts := reuseOrNewWithCallOptions(intOpts, retryOpts)\\n121: \\t\\t// short circuit for simplicity, and avoiding allocations.\\n122: \\t\\tif callOpts.max == 0 {\\n123: \\t\\t\\treturn streamer(ctx, desc, cc, method, grpcOpts...)\\n124: \\t\\t}\\n125: \\t\\tif desc.ClientStreams {\\n126: \\t\\t\\treturn nil, status.Errorf(codes.Unimplemented, \\\"clientv3/retry_interceptor: cannot retry on ClientStreams, set Disable()\\\")\\n127: \\t\\t}\\n128: \\t\\tnewStreamer, err := streamer(ctx, desc, cc, method, grpcOpts...)\\n129: \\t\\tif err != nil {\\n130: \\t\\t\\tc.GetLogger().Error(\\\"streamer failed to create ClientStream\\\", zap.Error(err))\\n131: \"}"}]},"parent_tool_use_id":"toolu_01DAE5YAhHYEdu717sYhdJrj","session_id":"ead0a24a-8a66-467d-a3b3-f81605cf654f","uuid":"b42946eb-c92d-41d9-9434-eedbf8958fe9","timestamp":"2026-03-31T21:46:45.238Z"}
