{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018uff5jF73eCbFHSDLGgKGo","type":"tool_result","content":"{\"text\":\"URL: https://demo.sourcegraph.com/github.com/sg-evals/etcd-io-etcd@17dae73b287c31f5cf3a70e48cf38a113a14f12a/-/blob/client/v3/retry_interceptor.go%3FL1-60\\n1: // Copyright 2016 The etcd Authors\\n2: //\\n3: // Licensed under the Apache License, Version 2.0 (the \\\"License\\\");\\n4: // you may not use this file except in compliance with the License.\\n5: // You may obtain a copy of the License at\\n6: //\\n7: //     http://www.apache.org/licenses/LICENSE-2.0\\n8: //\\n9: // Unless required by applicable law or agreed to in writing, software\\n10: // distributed under the License is distributed on an \\\"AS IS\\\" BASIS,\\n11: // WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\\n12: // See the License for the specific language governing permissions and\\n13: // limitations under the License.\\n14: \\n15: // Based on github.com/grpc-ecosystem/go-grpc-middleware/retry, but modified to support the more\\n16: // fine grained error checking required by write-at-most-once retry semantics of etcd.\\n17: \\n18: package clientv3\\n19: \\n20: import (\\n21: \\t\\\"context\\\"\\n22: \\t\\\"errors\\\"\\n23: \\t\\\"io\\\"\\n24: \\t\\\"sync\\\"\\n25: \\t\\\"time\\\"\\n26: \\n27: \\t\\\"go.etcd.io/etcd/api/v3/v3rpc/rpctypes\\\"\\n28: \\t\\\"go.uber.org/zap\\\"\\n29: \\t\\\"google.golang.org/grpc\\\"\\n30: \\t\\\"google.golang.org/grpc/codes\\\"\\n31: \\t\\\"google.golang.org/grpc/metadata\\\"\\n32: \\t\\\"google.golang.org/grpc/status\\\"\\n33: )\\n34: \\n35: // unaryClientInterceptor returns a new retrying unary client interceptor.\\n36: //\\n37: // The default configuration of the interceptor is to not retry *at all*. This behaviour can be\\n38: // changed through options (e.g. WithMax) on creation of the interceptor or on call (through grpc.CallOptions).\\n39: func (c *Client) unaryClientInterceptor(optFuncs ...retryOption) grpc.UnaryClientInterceptor {\\n40: \\tintOpts := reuseOrNewWithCallOptions(defaultOptions, optFuncs)\\n41: \\treturn func(ctx context.Context, method string, req, reply interface{}, cc *grpc.ClientConn, invoker grpc.UnaryInvoker, opts ...grpc.CallOption) error {\\n42: \\t\\tctx = withVersion(ctx)\\n43: \\t\\tgrpcOpts, retryOpts := filterCallOptions(opts)\\n44: \\t\\tcallOpts := reuseOrNewWithCallOptions(intOpts, retryOpts)\\n45: \\t\\t// short circuit for simplicity, and avoiding allocations.\\n46: \\t\\tif callOpts.max == 0 {\\n47: \\t\\t\\treturn invoker(ctx, method, req, reply, cc, grpcOpts...)\\n48: \\t\\t}\\n49: \\t\\tvar lastErr error\\n50: \\t\\tfor attempt := uint(0); attempt < callOpts.max; attempt++ {\\n51: \\t\\t\\tif err := waitRetryBackoff(ctx, attempt, callOpts); err != nil {\\n52: \\t\\t\\t\\treturn err\\n53: \\t\\t\\t}\\n54: \\t\\t\\tc.GetLogger().Debug(\\n55: \\t\\t\\t\\t\\\"retrying of unary invoker\\\",\\n56: \\t\\t\\t\\tzap.String(\\\"target\\\", cc.Target()),\\n57: \\t\\t\\t\\tzap.Uint(\\\"attempt\\\", attempt),\\n58: \\t\\t\\t)\\n59: \\t\\t\\tlastErr = invoker(ctx, method, req, reply, cc, grpcOpts...)\\n60: \\t\\t\\tif lastErr == nil {\\n61: \"}"}]},"parent_tool_use_id":"toolu_01DAE5YAhHYEdu717sYhdJrj","session_id":"ead0a24a-8a66-467d-a3b3-f81605cf654f","uuid":"cb95888f-5b55-44dc-a74a-53a0f0ec2e55","timestamp":"2026-03-31T21:46:35.249Z"}
