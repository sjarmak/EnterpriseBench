oxy/watch.go\",\n      \"api_used\": [],\n      \"breakage_type\": \"none\",\n      \"description\": \"Propagates stream.Context() (which carries incoming metadata) to child contexts. No direct metadata API calls; relies on AuthStreamClientInterceptor in util.go for token forwarding.\",\n      \"critical\": true,\n      \"forwarding_pattern\": \"context_propagation\"\n    },\n    {\n      \"path\": \"server/proxy/grpcproxy/lease.go\",\n      \"api_used\": [],\n      \"breakage_type\": \"none\",\n      \"description\": \"Passes incoming ctx directly to upstream client calls. AuthUnaryClientInterceptor in util.go handles token extraction and re-injection.\",\n      \"critical\": true,\n      \"forwarding_pattern\": \"context_propagation\"\n    },\n    {\n      \"path\": \"server/proxy/grpcproxy/adapter/chan_stream.go\",\n      \"api_used\": [\"metadata.MD type only\"],\n      \"breakage_type\": \"none\",\n      \"description\": \"Uses metadata.MD as a type for header/trailer channels in the in-process channel stream bridge. No FromContext or NewContext calls.\"\n    },\n    {\n      \"path\": \"server/etcdserver/api/v3rpc/interceptor.go\",\n      \"api_used\": [\"FromIncomingContext\"],\n      \"breakage_type\": \"compile_error\",\n      \"description\": \"Both unary and stream interceptors read MetadataClientAPIVersionKey (for metrics) and MetadataRequireLeaderKey (for leader gating) from incoming metadata. Read-only; no forwarding.\",\n      \"critical\": true\n    },\n    {\n      \"path\": \"pkg/grpc_testing/recorder.go\",\n      \"api_used\": [\"FromIncomingContext\"],\n      \"breakage_type\": \"compile_error\",\n      \"description\": \"Test helper reads :authority header from incoming context to record request info.\"\n    },\n    {\n      \"path\": \"tests/integration/v3_grpc_test.go\",\n      \"api_used\": [\"NewOutgoingContext\"],\n      \"breakage_type\": \"compile_error\",\n      \"description\": \"Integration tests set require-leader metadata on outgoing