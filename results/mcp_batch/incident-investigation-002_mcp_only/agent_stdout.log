infinitely on putting\n902\t\t// to c.result, when c.done is already closed.\n903\t\n904\t\t// This ensures that with c.done already close, we at most once go\n905\t\t// into the next select after this. With that, no matter which\n906\t\t// statement we choose there, we will deliver only consecutive\n907\t\t// events.\n908\t\tselect {\n909\t\tcase <-c.done:\n910\t\t\treturn\n911\t\tdefault:\n912\t\t}\n913\t\n914\t\tselect {\n915\t\tcase c.result <- watchEvent:\n916\t\tcase <-c.done:\n917\t\t}\n918\t}\n919\t\n920\tfunc (c *cacheWatcher) process(initEvents []*watchCacheEvent, resourceVersion uint64) {\n921\t\tdefer utilruntime.HandleCrash()\n922\t\n923\t\t// Check how long we are processing initEvents.\n924\t\t// As long as these are not processed, we are not processing\n925\t\t// any incoming events, so if it takes long, we may actually\n926\t\t// block all watchers for some time.\n927\t\t// TODO: From the logs it seems that there happens processing\n928\t\t// times even up to 1s which is very long. However, this doesn't\n929\t\t// depend that much on the number of initEvents. E.g. from the\n930\t\t// 2000-node Kubemark run we have logs like this, e.g.:\n931\t\t// ... processing 13862 initEvents took 66.808689ms\n932\t\t// ... processing 14040 initEvents took 993.532539ms\n933\t\t// We should understand what is blocking us in those cases (e.g.\n934\t\t// is it lack of CPU, network, or sth else) and potentially\n935\t\t// consider increase size of result buffer in those cases.\n936\t\tconst initProcessThreshold = 500 * time.Millisecond\n937\t\tstartTime := time.Now()\n938\t\tfor _, event := range initEvents {\n939\t\t\tc.sendWatchCacheEvent(event)\n940\t\t}\n941\t\tprocessingTime := time.Since(startTime)\n942\t\tif processingTime > initProcessThreshold {\n943\t\t\tobjType := \"<null>\"\n944\t\t\tif len(initEvents) > 0 {\n945\t\t\t\tobjType = reflect.TypeOf(initEvents[0].Object).String()\n946\t\t\t}\n947\t\t\tglog.V(2).Infof(\"processing %d initEvents of %s took %v\", len(initEvents), objType, processingTime)\n948\t\t}\n949\t\n950\t\tdefer close(c.result)\n951\t\tdefer c.Stop()\n952\t\tfor {\n953\t\t\tevent, ok := <-c.input\n954\t\t\tif !ok {\n955\t\t\t\treturn\n956\t\t\t}\n957\t\t\t// only send events newer than resourceVersion\n958\t\t\tif event.ResourceVersion > resourceVersion {\n959\t\t\t\tc.sendWatchCacheEvent(event)\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01WJDyNr2hKt2hiXCZDuSM9R","session_id":"9acb4ca3-911a-4067-a3ba-399174a3a531","uuid":"165671b0-2655-4ee4-b9b4-2f0e9850252d","timestamp":"2026-03-31T21:46:48.156Z"}
