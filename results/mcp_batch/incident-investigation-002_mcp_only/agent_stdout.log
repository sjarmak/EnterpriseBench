{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01P2SoEVWAQuztPuTNJ4RXD2","type":"tool_result","content":"# watchHandler Function: Lines 280-325\n\n```\n280\t// watchHandler watches w and keeps *resourceVersion up to date.\n281\tfunc (r *Reflector) watchHandler(w watch.Interface, resourceVersion *string, errc chan error, stopCh <-chan struct{}) error {\n282\t\tstart := r.clock.Now()\n283\t\teventCount := 0\n284\t\n285\t\t// Stopping the watcher should be idempotent and if we return from this function there's no way\n286\t\t// we're coming back in with the same watch interface.\n287\t\tdefer w.Stop()\n288\t\t// update metrics\n289\t\tdefer func() {\n290\t\tr.metrics.numberOfItemsInWatch.Observe(float64(eventCount))\n291\t\tr.metrics.watchDuration.Observe(time.Since(start).Seconds())\n292\t\t}()\n293\t\n294\tloop:\n295\t\tfor {\n296\t\tselect {\n297\t\tcase <-stopCh:\n298\t\t\treturn errorStopRequested\n299\t\tcase err := <-errc:\n300\t\t\treturn err\n301\t\tcase event, ok := <-w.ResultChan():\n302\t\t\tif !ok {\n303\t\t\t\tbreak loop\n304\t\t\t}\n305\t\t\tif event.Type == watch.Error {\n306\t\t\t\treturn apierrs.FromObject(event.Object)\n307\t\t\t}\n308\t\t\tif e, a := r.expectedType, reflect.TypeOf(event.Object); e != nil && e != a {\n309\t\t\t\tutilruntime.HandleError(fmt.Errorf(\"%s: expected type %v, but watch event object had type %v\", r.name, e, a))\n310\t\t\t\tcontinue\n311\t\t\t}\n312\t\t\tmeta, err := meta.Accessor(event.Object)\n313\t\t\tif err != nil {\n314\t\t\t\tutilruntime.HandleError(fmt.Errorf(\"%s: unable to understand watch event %#v\", r.name, event))\n315\t\t\t\tcontinue\n316\t\t\t}\n317\t\t\tnewResourceVersion := meta.GetResourceVersion()\n318\t\t\tswitch event.Type {\n319\t\t\tcase watch.Added:\n320\t\t\t\terr := r.store.Add(event.Object)\n321\t\t\t\tif err != nil {\n\t\t\t\t\tutilruntime.HandleError(fmt.Errorf(\"%s: unable to add watch event object (%#v) to store: %v\", r.name, event.Object, err))\n322\t\t\t\t}\n323\t\t\tcase watch.Modified:\n324\t\t\t\terr := r.store.Update(event.Object)\n325\t\t\t\tif err != nil {\n```\n\n## Key Points\n\n**Resource version extraction**: At line 317, the code retrieves the resource version via `newResourceVersion := meta.GetResourceVersion()`, extracting metadata from each incoming watch event object.\n\n**Resource version updates**: The pointer argument `resourceVersion` gets updated at line 330 (outside this range) with `*resourceVersion = newResourceVersion`, reflecting the latest observed state from the watch stream."}]},"parent_tool_use_id":"toolu_01Kc4heytELkPjZJGB3E7U2u","session_id":"9acb4ca3-911a-4067-a3ba-399174a3a531","uuid":"4fc48f14-abca-4c2d-bfb8-42d33e368f2c","timestamp":"2026-03-31T21:48:38.534Z"}
