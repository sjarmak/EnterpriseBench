{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015FLon42UQfojKDCaxp6apr","type":"tool_result","content":"{\"text\":\"URL: https://demo.sourcegraph.com/github.com/sg-evals/etcd--v3.3.0@e0db931df84a2dad5f2c30f150343a98d0d2b809/-/blob/etcdserver/api/v3rpc/interceptor.go%3FL35-90\\n35: )\\n36: \\n37: type streamsMap struct {\\n38: \\tmu      sync.Mutex\\n39: \\tstreams map[grpc.ServerStream]struct{}\\n40: }\\n41: \\n42: func newUnaryInterceptor(s *etcdserver.EtcdServer) grpc.UnaryServerInterceptor {\\n43: \\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\\n44: \\t\\tif !api.IsCapabilityEnabled(api.V3rpcCapability) {\\n45: \\t\\t\\treturn nil, rpctypes.ErrGRPCNotCapable\\n46: \\t\\t}\\n47: \\n48: \\t\\tmd, ok := metadata.FromIncomingContext(ctx)\\n49: \\t\\tif ok {\\n50: \\t\\t\\tif ks := md[rpctypes.MetadataRequireLeaderKey]; len(ks) > 0 && ks[0] == rpctypes.MetadataHasLeader {\\n51: \\t\\t\\t\\tif s.Leader() == types.ID(raft.None) {\\n52: \\t\\t\\t\\t\\treturn nil, rpctypes.ErrGRPCNoLeader\\n53: \\t\\t\\t\\t}\\n54: \\t\\t\\t}\\n55: \\t\\t}\\n56: \\n57: \\t\\treturn prometheus.UnaryServerInterceptor(ctx, req, info, handler)\\n58: \\t}\\n59: }\\n60: \\n61: func newStreamInterceptor(s *etcdserver.EtcdServer) grpc.StreamServerInterceptor {\\n62: \\tsmap := monitorLeader(s)\\n63: \\n64: \\treturn func(srv interface{}, ss grpc.ServerStream, info *grpc.StreamServerInfo, handler grpc.StreamHandler) error {\\n65: \\t\\tif !api.IsCapabilityEnabled(api.V3rpcCapability) {\\n66: \\t\\t\\treturn rpctypes.ErrGRPCNotCapable\\n67: \\t\\t}\\n68: \\n69: \\t\\tmd, ok := metadata.FromIncomingContext(ss.Context())\\n70: \\t\\tif ok {\\n71: \\t\\t\\tif ks := md[rpctypes.MetadataRequireLeaderKey]; len(ks) > 0 && ks[0] == rpctypes.MetadataHasLeader {\\n72: \\t\\t\\t\\tif s.Leader() == types.ID(raft.None) {\\n73: \\t\\t\\t\\t\\treturn rpctypes.ErrGRPCNoLeader\\n74: \\t\\t\\t\\t}\\n75: \\n76: \\t\\t\\t\\tcctx, cancel := context.WithCancel(ss.Context())\\n77: \\t\\t\\t\\tss = serverStreamWithCtx{ctx: cctx, cancel: &cancel, ServerStream: ss}\\n78: \\n79: \\t\\t\\t\\tsmap.mu.Lock()\\n80: \\t\\t\\t\\tsmap.streams[ss] = struct{}{}\\n81: \\t\\t\\t\\tsmap.mu.Unlock()\\n82: \\n83: \\t\\t\\t\\tdefer func() {\\n84: \\t\\t\\t\\t\\tsmap.mu.Lock()\\n85: \\t\\t\\t\\t\\tdelete(smap.streams, ss)\\n86: \\t\\t\\t\\t\\tsmap.mu.Unlock()\\n87: \\t\\t\\t\\t\\tcancel()\\n88: \\t\\t\\t\\t}()\\n89: \\n90: \\t\\t\\t}\\n91: \"}"}]},"parent_tool_use_id":"toolu_01XckfNxaFSdevMqaooMrtgP","session_id":"9c6a61d1-0fa0-43c6-80f7-1a961d909727","uuid":"59fb2d7c-531e-4a34-9da2-de256db9c63b","timestamp":"2026-04-01T01:22:14.344Z"}
