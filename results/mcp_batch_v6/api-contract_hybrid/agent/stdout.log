{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0112d1GH8DuktptB65CLRsau","type":"tool_result","content":"{\"text\":\"URL: https://demo.sourcegraph.com/github.com/sg-evals/etcd--d89978e8@d89978e8e32196a3d7410690ebed1d94baf32dbe/-/blob/server/auth/store.go%3FL1020-1080\\n1020: \\tfor _, chains := range tlsInfo.State.VerifiedChains {\\n1021: \\t\\tif len(chains) < 1 {\\n1022: \\t\\t\\tcontinue\\n1023: \\t\\t}\\n1024: \\t\\tai = &AuthInfo{\\n1025: \\t\\t\\tUsername: chains[0].Subject.CommonName,\\n1026: \\t\\t\\tRevision: as.Revision(),\\n1027: \\t\\t}\\n1028: \\t\\tmd, ok := metadata.FromIncomingContext(ctx)\\n1029: \\t\\tif !ok {\\n1030: \\t\\t\\treturn nil\\n1031: \\t\\t}\\n1032: \\n1033: \\t\\t// gRPC-gateway proxy request to etcd server includes Grpcgateway-Accept\\n1034: \\t\\t// header. The proxy uses etcd client server certificate. If the certificate\\n1035: \\t\\t// has a CommonName we should never use this for authentication.\\n1036: \\t\\tif gw := md[\\\"grpcgateway-accept\\\"]; len(gw) > 0 {\\n1037: \\t\\t\\tas.lg.Warn(\\n1038: \\t\\t\\t\\t\\\"ignoring common name in gRPC-gateway proxy request\\\",\\n1039: \\t\\t\\t\\tzap.String(\\\"common-name\\\", ai.Username),\\n1040: \\t\\t\\t\\tzap.String(\\\"user-name\\\", ai.Username),\\n1041: \\t\\t\\t\\tzap.Uint64(\\\"revision\\\", ai.Revision),\\n1042: \\t\\t\\t)\\n1043: \\t\\t\\treturn nil\\n1044: \\t\\t}\\n1045: \\t\\tas.lg.Debug(\\n1046: \\t\\t\\t\\\"found command name\\\",\\n1047: \\t\\t\\tzap.String(\\\"common-name\\\", ai.Username),\\n1048: \\t\\t\\tzap.String(\\\"user-name\\\", ai.Username),\\n1049: \\t\\t\\tzap.Uint64(\\\"revision\\\", ai.Revision),\\n1050: \\t\\t)\\n1051: \\t\\tbreak\\n1052: \\t}\\n1053: \\treturn ai\\n1054: }\\n1055: \\n1056: func (as *authStore) AuthInfoFromCtx(ctx context.Context) (*AuthInfo, error) {\\n1057: \\tif !as.IsAuthEnabled() {\\n1058: \\t\\treturn nil, nil\\n1059: \\t}\\n1060: \\n1061: \\tmd, ok := metadata.FromIncomingContext(ctx)\\n1062: \\tif !ok {\\n1063: \\t\\treturn nil, nil\\n1064: \\t}\\n1065: \\n1066: \\t// TODO(mitake|hexfusion) review unifying key names\\n1067: \\tts, ok := md[rpctypes.TokenFieldNameGRPC]\\n1068: \\tif !ok {\\n1069: \\t\\tts, ok = md[rpctypes.TokenFieldNameSwagger]\\n1070: \\t}\\n1071: \\tif !ok {\\n1072: \\t\\treturn nil, nil\\n1073: \\t}\\n1074: \\n1075: \\ttoken := ts[0]\\n1076: \\tauthInfo, uok := as.authInfoFromToken(ctx, token)\\n1077: \\tif !uok {\\n1078: \\t\\ttokenFingerprint := redactToken(token)\\n1079: \\t\\tas.lg.Warn(\\\"invalid auth token\\\", zap.String(\\\"token-fingerprint\\\", tokenFingerprint))\\n1080: \\t\\treturn nil, ErrInvalidAuthToken\\n1081: \"}"}]},"parent_tool_use_id":"toolu_01XckfNxaFSdevMqaooMrtgP","session_id":"9c6a61d1-0fa0-43c6-80f7-1a961d909727","uuid":"5886fb47-5bbc-4887-a4c1-a13a28d1a6ca","timestamp":"2026-04-01T01:22:32.280Z"}
