{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ScqxDuAXHWbJw4HJzFrb5J","type":"tool_result","content":"{\"text\":\"URL: https://demo.sourcegraph.com/github.com/sg-evals/grpc-go--v1.4.0@5388deabdcad2a689731713b54a5373263b3657c/-/blob/metadata/metadata.go\\n1: /*\\n2:  *\\n3:  * Copyright 2014, Google Inc.\\n4:  * All rights reserved.\\n5:  *\\n6:  * Redistribution and use in source and binary forms, with or without\\n7:  * modification, are permitted provided that the following conditions are\\n8:  * met:\\n9:  *\\n10:  *     * Redistributions of source code must retain the above copyright\\n11:  * notice, this list of conditions and the following disclaimer.\\n12:  *     * Redistributions in binary form must reproduce the above\\n13:  * copyright notice, this list of conditions and the following disclaimer\\n14:  * in the documentation and/or other materials provided with the\\n15:  * distribution.\\n16:  *     * Neither the name of Google Inc. nor the names of its\\n17:  * contributors may be used to endorse or promote products derived from\\n18:  * this software without specific prior written permission.\\n19:  *\\n20:  * THIS SOFTWARE IS PROVIDED BY THE COPYRIGHT HOLDERS AND CONTRIBUTORS\\n21:  * \\\"AS IS\\\" AND ANY EXPRESS OR IMPLIED WARRANTIES, INCLUDING, BUT NOT\\n22:  * LIMITED TO, THE IMPLIED WARRANTIES OF MERCHANTABILITY AND FITNESS FOR\\n23:  * A PARTICULAR PURPOSE ARE DISCLAIMED. IN NO EVENT SHALL THE COPYRIGHT\\n24:  * OWNER OR CONTRIBUTORS BE LIABLE FOR ANY DIRECT, INDIRECT, INCIDENTAL,\\n25:  * SPECIAL, EXEMPLARY, OR CONSEQUENTIAL DAMAGES (INCLUDING, BUT NOT\\n26:  * LIMITED TO, PROCUREMENT OF SUBSTITUTE GOODS OR SERVICES; LOSS OF USE,\\n27:  * DATA, OR PROFITS; OR BUSINESS INTERRUPTION) HOWEVER CAUSED AND ON ANY\\n28:  * THEORY OF LIABILITY, WHETHER IN CONTRACT, STRICT LIABILITY, OR TORT\\n29:  * (INCLUDING NEGLIGENCE OR OTHERWISE) ARISING IN ANY WAY OUT OF THE USE\\n30:  * OF THIS SOFTWARE, EVEN IF ADVISED OF THE POSSIBILITY OF SUCH DAMAGE.\\n31:  *\\n32:  */\\n33: \\n34: // Package metadata define the structure of the metadata supported by gRPC library.\\n35: // Please refer to http://www.grpc.io/docs/guides/wire.html for more information about custom-metadata.\\n36: package metadata // import \\\"google.golang.org/grpc/metadata\\\"\\n37: \\n38: import (\\n39: \\t\\\"fmt\\\"\\n40: \\t\\\"strings\\\"\\n41: \\n42: \\t\\\"golang.org/x/net/context\\\"\\n43: )\\n44: \\n45: // DecodeKeyValue returns k, v, nil.  It is deprecated and should not be used.\\n46: func DecodeKeyValue(k, v string) (string, string, error) {\\n47: \\treturn k, v, nil\\n48: }\\n49: \\n50: // MD is a mapping from metadata keys to values. Users should use the following\\n51: // two convenience functions New and Pairs to generate MD.\\n52: type MD map[string][]string\\n53: \\n54: // New creates an MD from a given key-value map.\\n55: // Keys are automatically converted to lowercase.\\n56: func New(m map[string]string) MD {\\n57: \\tmd := MD{}\\n58: \\tfor k, val := range m {\\n59: \\t\\tkey := strings.ToLower(k)\\n60: \\t\\tmd[key] = append(md[key], val)\\n61: \\t}\\n62: \\treturn md\\n63: }\\n64: \\n65: // Pairs returns an MD formed by the mapping of key, value ...\\n66: // Pairs panics if len(kv) is odd.\\n67: // Keys are automatically converted to lowercase.\\n68: func Pairs(kv ...string) MD {\\n69: \\tif len(kv)%2 == 1 {\\n70: \\t\\tpanic(fmt.Sprintf(\\\"metadata: Pairs got the odd number of input pairs for metadata: %d\\\", len(kv)))\\n71: \\t}\\n72: \\tmd := MD{}\\n73: \\tvar key string\\n74: \\tfor i, s := range kv {\\n75: \\t\\tif i%2 == 0 {\\n76: \\t\\t\\tkey = strings.ToLower(s)\\n77: \\t\\t\\tcontinue\\n78: \\t\\t}\\n79: \\t\\tmd[key] = append(md[key], s)\\n80: \\t}\\n81: \\treturn md\\n82: }\\n83: \\n84: // Len returns the number of items in md.\\n85: func (md MD) Len() int {\\n86: \\treturn len(md)\\n87: }\\n88: \\n89: // Copy returns a copy of md.\\n90: func (md MD) Copy() MD {\\n91: \\treturn Join(md)\\n92: }\\n93: \\n94: // Join joins any number of mds into a single MD.\\n95: // The order of values for each key is determined by the order in which\\n96: // the mds containing those values are presented to Join.\\n97: func Join(mds ...MD) MD {\\n98: \\tout := MD{}\\n99: \\tfor _, md := range mds {\\n100: \\t\\tfor k, v := range md {\\n101: \\t\\t\\tout[k] = append(out[k], v...)\\n102: \\t\\t}\\n103: \\t}\\n104: \\treturn out\\n105: }\\n106: \\n107: type mdIncomingKey struct{}\\n108: type mdOutgoingKey struct{}\\n109: \\n110: // NewContext is a wrapper for NewOutgoingContext(ctx, md).  Deprecated.\\n111: func NewContext(ctx context.Context, md MD) context.Context {\\n112: \\treturn NewOutgoingContext(ctx, md)\\n113: }\\n114: \\n115: // NewIncomingContext creates a new context with incoming md attached.\\n116: func NewIncomingContext(ctx context.Context, md MD) context.Context {\\n117: \\treturn context.WithValue(ctx, mdIncomingKey{}, md)\\n118: }\\n119: \\n120: // NewOutgoingContext creates a new context with outgoing md attached.\\n121: func NewOutgoingContext(ctx context.Context, md MD) context.Context {\\n122: \\treturn context.WithValue(ctx, mdOutgoingKey{}, md)\\n123: }\\n124: \\n125: // FromContext is a wrapper for FromIncomingContext(ctx).  Deprecated.\\n126: func FromContext(ctx context.Context) (md MD, ok bool) {\\n127: \\treturn FromIncomingContext(ctx)\\n128: }\\n129: \\n130: // FromIncomingContext returns the incoming metadata in ctx if it exists.  The\\n131: // returned MD should not be modified. Writing to it may cause races.\\n132: // Modification should be made to copies of the returned MD.\\n133: func FromIncomingContext(ctx context.Context) (md MD, ok bool) {\\n134: \\tmd, ok = ctx.Value(mdIncomingKey{}).(MD)\\n135: \\treturn\\n136: }\\n137: \\n138: // FromOutgoingContext returns the outgoing metadata in ctx if it exists.  The\\n139: // returned MD should not be modified. Writing to it may cause races.\\n140: // Modification should be made to the copies of the returned MD.\\n141: func FromOutgoingContext(ctx context.Context) (md MD, ok bool) {\\n142: \\tmd, ok = ctx.Value(mdOutgoingKey{}).(MD)\\n143: \\treturn\\n144: }\\n145: \"}"}]},"parent_tool_use_id":"toolu_01XckfNxaFSdevMqaooMrtgP","session_id":"9c6a61d1-0fa0-43c6-80f7-1a961d909727","uuid":"d52e9074-2522-4545-81d0-a6899d9b8d83","timestamp":"2026-04-01T01:21:40.740Z"}
