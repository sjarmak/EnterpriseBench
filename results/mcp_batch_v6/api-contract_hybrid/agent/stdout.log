{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017YH7dnvyRzcNZV6MhQHfCu","type":"tool_result","content":"{\"text\":\"URL: https://demo.sourcegraph.com/github.com/sg-evals/etcd--d89978e8@d89978e8e32196a3d7410690ebed1d94baf32dbe/-/blob/server/etcdserver/api/v3rpc/interceptor.go%3FL40-100\\n40: \\n41: type streamsMap struct {\\n42: \\tmu      sync.Mutex\\n43: \\tstreams map[grpc.ServerStream]struct{}\\n44: }\\n45: \\n46: func newUnaryInterceptor(s *etcdserver.EtcdServer) grpc.UnaryServerInterceptor {\\n47: \\treturn func(ctx context.Context, req any, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (any, error) {\\n48: \\t\\tif !api.IsCapabilityEnabled(api.V3rpcCapability) {\\n49: \\t\\t\\treturn nil, rpctypes.ErrGRPCNotCapable\\n50: \\t\\t}\\n51: \\n52: \\t\\tif s.IsMemberExist(s.MemberID()) && s.IsLearner() && !isRPCSupportedForLearner(req) {\\n53: \\t\\t\\treturn nil, rpctypes.ErrGRPCNotSupportedForLearner\\n54: \\t\\t}\\n55: \\n56: \\t\\tmd, ok := metadata.FromIncomingContext(ctx)\\n57: \\t\\tif ok {\\n58: \\t\\t\\tver, vs := \\\"unknown\\\", md.Get(rpctypes.MetadataClientAPIVersionKey)\\n59: \\t\\t\\tif len(vs) > 0 {\\n60: \\t\\t\\t\\tver = vs[0]\\n61: \\t\\t\\t}\\n62: \\t\\t\\tif !utf8.ValidString(ver) {\\n63: \\t\\t\\t\\treturn nil, rpctypes.ErrGRPCInvalidClientAPIVersion\\n64: \\t\\t\\t}\\n65: \\t\\t\\tclientRequests.WithLabelValues(\\\"unary\\\", ver).Inc()\\n66: \\n67: \\t\\t\\tif ks := md[rpctypes.MetadataRequireLeaderKey]; len(ks) > 0 && ks[0] == rpctypes.MetadataHasLeader {\\n68: \\t\\t\\t\\tif s.Leader() == types.ID(raft.None) {\\n69: \\t\\t\\t\\t\\treturn nil, rpctypes.ErrGRPCNoLeader\\n70: \\t\\t\\t\\t}\\n71: \\t\\t\\t}\\n72: \\t\\t}\\n73: \\n74: \\t\\treturn handler(ctx, req)\\n75: \\t}\\n76: }\\n77: \\n78: func newLogUnaryInterceptor(s *etcdserver.EtcdServer) grpc.UnaryServerInterceptor {\\n79: \\treturn func(ctx context.Context, req any, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (any, error) {\\n80: \\t\\tstartTime := time.Now()\\n81: \\t\\tresp, err := handler(ctx, req)\\n82: \\t\\tlg := s.Logger()\\n83: \\t\\tif lg != nil { // acquire stats if debug level is enabled or RequestInfo is expensive\\n84: \\t\\t\\tdefer logUnaryRequestStats(ctx, lg, s.Cfg.WarningUnaryRequestDuration, info, startTime, req, resp)\\n85: \\t\\t}\\n86: \\t\\treturn resp, err\\n87: \\t}\\n88: }\\n89: \\n90: func logUnaryRequestStats(ctx context.Context, lg *zap.Logger, warnLatency time.Duration, info *grpc.UnaryServerInfo, startTime time.Time, req any, resp any) {\\n91: \\tduration := time.Since(startTime)\\n92: \\tvar enabledDebugLevel, expensiveRequest bool\\n93: \\tif lg.Core().Enabled(zap.DebugLevel) {\\n94: \\t\\tenabledDebugLevel = true\\n95: \\t}\\n96: \\tif duration > warnLatency {\\n97: \\t\\texpensiveRequest = true\\n98: \\t}\\n99: \\tif !enabledDebugLevel && !expensiveRequest {\\n100: \\t\\treturn\\n101: \"}"}]},"parent_tool_use_id":"toolu_01XckfNxaFSdevMqaooMrtgP","session_id":"9c6a61d1-0fa0-43c6-80f7-1a961d909727","uuid":"17c9b95f-f077-48f6-8519-4f342b0cfcac","timestamp":"2026-04-01T01:22:21.732Z"}
