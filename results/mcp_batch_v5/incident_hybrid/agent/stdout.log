r\n56\t\n57\t\t// The Cache will be caching objects of a given Type and assumes that they\n58\t\t// are all stored under ResourcePrefix directory in the underlying database.\n59\t\tType           interface{}\n60\t\tResourcePrefix string\n61\t\n62\t\t// KeyFunc is used to get a key in the underlying storage for a given object.\n63\t\tKeyFunc func(runtime.Object) (string, error)\n64\t\n65\t\t// GetAttrsFunc is used to get object labels, fields, and the uninitialized bool\n66\t\tGetAttrsFunc func(runtime.Object) (label labels.Set, field fields.Set, uninitialized bool, err error)\n67\t\n68\t\t// TriggerPublisherFunc is used for optimizing amount of watchers that\n69\t\t// needs to process an incoming event.\n70\t\tTriggerPublisherFunc TriggerPublisherFunc\n71\t\n72\t\t// NewList is a function that creates new empty object storing a list of\n73\t\t// objects of type Type.\n74\t\tNewListFunc func() runtime.Object\n75\t\n76\t\tCodec runtime.Codec\n77\t}\n78\t\n79\ttype watchersMap map[int]*cacheWatcher\n80\t\n81\tfunc (wm watchersMap) addWatcher(w *cacheWatcher, number int) {\n82\t\twm[number] = w\n83\t}\n84\t\n85\tfunc (wm watchersMap) deleteWatcher(number int) {\n86\t\tdelete(wm, number)\n87\t}\n88\t\n89\tfunc (wm watchersMap) terminateAll() {\n90\t\tfor key, watcher := range wm {\n91\t\t\tdelete(wm, key)\n92\t\t\twatcher.stop()\n93\t\t}\n94\t}\n95\t\n96\ttype indexedWatchers struct {\n97\t\tallWatchers   watchersMap\n98\t\tvalueWatchers map[string]watchersMap\n99\t}\n100\t\n101\tfunc (i *indexedWatchers) addWatcher(w *cacheWatcher, number int, value string, supported bool) {\n102\t\tif supported {\n103\t\t\tif _, ok := i.valueWatchers[value]; !ok {\n104\t\t\t\ti.valueWatchers[value] = watchersMap{}\n105\t\t\t}\n106\t\t\ti.valueWatchers[value].addWatcher(w, number)\n107\t\t} else {\n108\t\t\ti.allWatchers.addWatcher(w, number)\n109\t\t}\n110\t}\n111\t\n112\tfunc (i *indexedWatchers) deleteWatcher(number int, value string, supported bool) {\n113\t\tif supported {\n114\t\t\ti.valueWatchers[value].deleteWatcher(number)\n115\t\t\tif len(i.valueWatchers[value]) == 0 {\n116\t\t\t\tdelete(i.valueWatchers, value)\n117\t\t\t}\n118\t\t} else {\n119\t\t\ti.allWatchers.deleteWatcher(number)\n120\t\t}\n121\t}\n122\t\n123\tfunc (i *indexedWatchers) terminateAll(objectType reflect.Type) {\n124\t\tif len(i.allWatchers) > 0 || len(i.valueWatchers) > 0 {\n125\t\t\tglog.Warningf(\"Terminating all watchers from cacher %v\", objectType)\n126\t\t}\n127\t\ti.allWatchers.terminateAll()\n128\t\tfor index, watchers := range i.valueWatchers {\n129\t\t\twatchers.terminateAll()\n130\t\t\tdelete(i.valueWatchers, index)\n131\t\t}\n132\t}\n133\t\n134\ttype watchFilterFunc func(key string, l labels.Set, f fields.Set, uninitialized bool) bool\n135\t\n136\t// Cacher is responsible for serving WATCH and LIST requests for a given\n137\t// resource from its internal cache and updating its cache in the background\n138\t// based on the underlying storage contents.\n139\t// Cacher implements storage.Interface (although most of the calls are just\n140\t// delegated to the underlying storage).\n141\ttype Cacher struct {\n142\t\t// HighWaterMarks for performance debugging.\n143\t\t// Important: Since HighWaterMark is using sync/atomic, it has to be at the top of the struct due to a bug on 32-bit platforms\n144\t\t// See: https://golang.org/pkg/sync/atomic/ for more information\n145\t\tincomingHWM HighWaterMark\n146\t\t// Incoming events that should be dispatched to watchers.\n147\t\tincoming chan watchCacheEvent\n148\t\n149\t\tsync.RWMutex\n150\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"1f1f0a74-24be-4718-b9fa-cd0683534a46","uuid":"3