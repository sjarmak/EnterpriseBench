{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015J6BxsiMyVzhcvg8R9iC6E","type":"tool_result","content":"150\t\n151\t\t// Before accessing the cacher's cache, wait for the ready to be ok.\n152\t\t// This is necessary to prevent users from accessing structures that are\n153\t\t// uninitialized or are being repopulated right now.\n154\t\t// ready needs to be set to false when the cacher is paused or stopped.\n155\t\t// ready needs to be set to true when the cacher is ready to use after\n156\t\t// initialization.\n157\t\tready *ready\n158\t\n159\t\t// Underlying storage.Interface.\n160\t\tstorage Interface\n161\t\n162\t\t// Expected type of objects in the underlying cache.\n163\t\tobjectType reflect.Type\n164\t\n165\t\t// \"sliding window\" of recent changes of objects and the current state.\n166\t\twatchCache *watchCache\n167\t\treflector  *cache.Reflector\n168\t\n169\t\t// Versioner is used to handle resource versions.\n170\t\tversioner Versioner\n171\t\n172\t\t// triggerFunc is used for optimizing amount of watchers that needs to process\n173\t\t// an incoming event.\n174\t\ttriggerFunc TriggerPublisherFunc\n175\t\t// watchers is mapping from the value of trigger function that a\n176\t\t// watcher is interested into the watchers\n177\t\twatcherIdx int\n178\t\twatchers   indexedWatchers\n179\t\n180\t\t// Defines a time budget that can be spend on waiting for not-ready watchers\n181\t\t// while dispatching event before shutting them down.\n182\t\tdispatchTimeoutBudget *timeBudget\n183\t\n184\t\t// Handling graceful termination.\n185\t\tstopLock sync.RWMutex\n186\t\tstopped  bool\n187\t\tstopCh   chan struct{}\n188\t\tstopWg   sync.WaitGroup\n189\t}\n190\t\n191\t// Create a new Cacher responsible for servicing WATCH and LIST requests from\n192\t// its internal cache and updating its cache in the background based on the\n193\t// given configuration.\n194\tfunc NewCacherFromConfig(config CacherConfig) *Cacher {\n195\t\twatchCache := newWatchCache(config.CacheCapacity, config.KeyFunc, config.GetAttrsFunc)\n196\t\tlisterWatcher := newCacherListerWatcher(config.Storage, config.ResourcePrefix, config.NewListFunc)\n197\t\treflectorName := \"storage/cacher.go:\" + config.ResourcePrefix\n198\t\n199\t\t// Give this error when it is constructed rather than when you get the\n200\t\t// first watch item, because it's much easier to track down that way.\n201\t\tif obj, ok := config.Type.(runtime.Object); ok {\n202\t\t\tif err := runtime.CheckCodec(config.Codec, obj); err != nil {\n203\t\t\t\tpanic(\"storage codec doesn't seem to match given type: \" + err.Error())\n204\t\t\t}\n205\t\t}\n206\t\n207\t\tstopCh := make(chan struct{})\n208\t\tcacher := &Cacher{\n209\t\t\tready:       newReady(),\n210\t\t\tstorage:     config.Storage,\n211\t\t\tobjectType:  reflect.TypeOf(config.Type),\n212\t\t\twatchCache:  watchCache,\n213\t\t\treflector:   cache.NewNamedReflector(reflectorName, listerWatcher, config.Type, watchCache, 0),\n214\t\t\tversioner:   config.Versioner,\n215\t\t\ttriggerFunc: config.TriggerPublisherFunc,\n216\t\t\twatcherIdx:  0,\n217\t\t\twatchers: indexedWatchers{\n218\t\t\t\tallWatchers:   make(map[int]*cacheWatcher),\n219\t\t\t\tvalueWatchers: make(map[string]watchersMap),\n220\t\t\t},\n221\t\t\t// TODO: Figure out the correct value for the buffer size.\n222\t\t\tincoming:              make(chan watchCacheEvent, 100),\n223\t\t\tdispatchTimeoutBudget: newTimeBudget(stopCh),\n224\t\t\t// We need to (potentially) stop both:\n225\t\t\t// - wait.Until go-routine\n226\t\t\t// - reflector.ListAndWatch\n227\t\t\t// and there are no guarantees on the order that they will stop.\n228\t\t\t// So we will be simply closing the channel, and synchronizing on the WaitGroup.\n229\t\t\tstopCh: stopCh,\n230\t\t}\n231\t\twatchCache.SetOnEvent(cacher.processEvent)\n232\t\tgo cacher.dispatchEvents()\n233\t\n234\t\tcacher.stopWg.Add(1)\n235\t\tgo func() {\n236\t\t\tdefer cacher.stopWg.Done()\n237\t\t\twait.Until(\n238\t\t\t\tfunc() {\n239\t\t\t\t\tif !cacher.isStopped() {\n240\t\t\t\t\t\tcacher.startCaching(stopCh)\n241\t\t\t\t\t}\n242\t\t\t\t}, time.Second, stopCh,\n243\t\t\t)\n244\t\t}()\n245\t\treturn cacher\n246\t}\n247\t\n248\tfunc (c *Cacher) startCaching(stopChannel <-chan struct{}) {\n249\t\t// The 'usable' lock is always 'RLock'able when it is safe to use the cache.\n250\t\t// It is safe to use the cache after a successful list until a disconnection.\n251\t\t// We start with usable (write) locked. The below OnReplace function will\n252\t\t// unlock it after a successful list. The below defer will then re-lock\n253\t\t// it when this function exits (always due to disconnection), only if\n254\t\t// we actually got a successful list. This cycle will repeat as needed.\n255\t\tsuccessfulList := false\n256\t\tc.watchCache.SetOnReplace(func() {\n257\t\t\tsuccessfulList = true\n258\t\t\tc.ready.set(true)\n259\t\t})\n260\t\tdefer func() {\n261\t\t\tif successfulList {\n262\t\t\t\tc.ready.set(false)\n263\t\t\t}\n264\t\t}()\n265\t\n266\t\tc.terminateAllWatchers()\n267\t\t// Note that since onReplace may be not called due to errors, we explicitly\n268\t\t// need to retry it on errors under lock.\n269\t\t// Also note that startCaching is called in a loop, so there's no need\n270\t\t// to have another loop here.\n271\t\tif err := c.reflector.ListAndWatch(stopChannel); err != nil {\n272\t\t\tglog.Errorf(\"unexpected ListAndWatch error: %v\", err)\n273\t\t}\n274\t}\n275\t\n276\t// Implements storage.Interface.\n277\tfunc (c *Cacher) Versioner() Versioner {\n278\t\treturn c.storage.Versioner()\n279\t}\n280\t\n281\t// Implements storage.Interface.\n282\tfunc (c *Cacher) Create(ctx context.Context, key string, obj, out runtime.Object, ttl uint64) error {\n283\t\treturn c.storage.Create(ctx, key, obj, out, ttl)\n284\t}\n285\t\n286\t// Implements storage.Interface.\n287\tfunc (c *Cacher) Delete(ctx context.Context, key string, out runtime.Object, preconditions *Preconditions) error {\n288\t\treturn c.storage.Delete(ctx, key, out, preconditions)\n289\t}\n290\t\n291\t// Implements storage.Interface.\n292\tfunc (c *Cacher) Watch(ctx context.Context, key string, resourceVersion string, pred SelectionPredicate) (watch.Interface, error) {\n293\t\twatchRV, err := ParseWatchResourceVersion(resourceVersion)\n294\t\tif err != nil {\n295\t\t\treturn nil, err\n296\t\t}\n297\t\n298\t\tc.ready.wait()\n299\t\n300\t\t// We explicitly use thread unsafe version and do locking ourself to ensure that\n301\t\t// no new events will be processed in the meantime. The watchCache will be unlocked\n302\t\t// on return from this function.\n303\t\t// Note that we cannot do it under Cacher lock, to avoid a deadlock, since the\n304\t\t// underlying watchCache is calling processEvent under its lock.\n305\t\tc.watchCache.RLock()\n306\t\tdefer c.watchCache.RUnlock()\n307\t\tinitEvents, err := c.watchCache.GetAllEventsSinceThreadUnsafe(watchRV)\n308\t\tif err != nil {\n309\t\t\t// To match the uncached watch implementation, once we have passed authn/authz/admission,\n310\t\t\t// and successfully parsed a resource version, other errors must fail with a watch event of type ERROR,\n311\t\t\t// rather than a directly returned error.\n312\t\t\treturn newErrWatcher(err), nil\n313\t\t}\n314\t\n315\t\ttriggerValue, triggerSupported := \"\", false\n316\t\t// TODO: Currently we assume that in a given Cacher object, any <predicate> that is\n317\t\t// passed here is aware of exactly the same trigger (at most one).\n318\t\t// Thus, either 0 or 1 values will be returned.\n319\t\tif matchValues := pred.MatcherIndex(); len(matchValues) > 0 {\n320\t\t\ttriggerValue, triggerSupported = matchValues[0].Value, true\n321\t\t}\n322\t\n323\t\t// If there is triggerFunc defined, but triggerSupported is false,\n324\t\t// we can't narrow the amount of events significantly at this point.\n325\t\t//\n326\t\t// That said, currently triggerFunc is defined only for Pods and Nodes,\n327\t\t// and there is only constant number of watc