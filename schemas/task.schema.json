{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EnterpriseBench Task Definition",
  "description": "Schema for task.toml files defining benchmark tasks",
  "type": "object",
  "required": ["task", "repos", "checkpoints", "artifacts"],
  "properties": {
    "task": {
      "type": "object",
      "required": ["id", "suite", "difficulty", "session_type"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique task identifier: {suite_prefix}-{description}-{number}",
          "pattern": "^[a-z][a-z0-9-]+-\\d{3}$"
        },
        "suite": {
          "type": "string",
          "enum": [
            "dependency_management",
            "incident_response",
            "platform_engineering",
            "security_operations",
            "customer_escalation",
            "feature_delivery",
            "technical_debt"
          ]
        },
        "difficulty": {
          "type": "string",
          "enum": ["medium", "hard", "expert"]
        },
        "estimated_duration_minutes": {
          "type": "integer",
          "minimum": 5,
          "maximum": 480
        },
        "session_type": {
          "type": "string",
          "enum": ["single", "chain", "event_replay", "resume"]
        },
        "session_count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10,
          "description": "Only for session_type=chain"
        },
        "description": {
          "type": "string",
          "description": "Human-readable task description"
        },
        "prompt": {
          "type": "string",
          "description": "The instruction given to the agent"
        },
        "task_type": {
          "type": "string",
          "enum": [
            "api_contract",
            "refactor_orchestration",
            "dependency_graph",
            "monorepo_boundary",
            "db_schema_evolution",
            "error_provenance",
            "support_code_mapping",
            "dead_code_necropsy",
            "incident_investigation",
            "config_drift"
          ],
          "description": "Task type classification from the 10 EnterpriseBench task types"
        }
      }
    },
    "repos": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["url", "rev", "path"],
        "properties": {
          "url": {
            "type": "string",
            "description": "Repository URL (github.com/org/repo)"
          },
          "rev": {
            "type": "string",
            "description": "Pinned revision (tag, commit hash, or branch)"
          },
          "path": {
            "type": "string",
            "description": "Directory name under /workspace/"
          },
          "role": {
            "type": "string",
            "enum": [
              "primary",
              "dependency",
              "consumer",
              "upstream",
              "intermediary",
              "deprecated_upstream"
            ],
            "description": "Repo's role in the task"
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "languages": {
          "type": "array",
          "items": { "type": "string" }
        },
        "total_loc": {
          "type": "integer",
          "description": "Combined lines of code across all repos"
        },
        "max_complexity": {
          "type": "number",
          "description": "Highest cyclomatic complexity score"
        },
        "dependency_depth": {
          "type": "integer",
          "description": "Depth of dependency chain (1 = single repo)"
        },
        "frameworks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "multi_repo_pattern": {
          "type": "string",
          "enum": ["propagate", "investigate", "enforce", "orchestrate"],
          "description": "Primary multi-repo interaction pattern"
        }
      }
    },
    "checkpoints": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["name", "weight", "verifier"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Human-readable checkpoint name"
          },
          "weight": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Score weight (all weights must sum to 1.0)"
          },
          "verifier": {
            "type": "string",
            "description": "Path to checkpoint verifier script. Must write JSON conforming to verifier_output.schema.json to stdout. Fallback: exit 0 = {score: 1.0, passed: true}, exit nonzero = {score: 0.0, passed: false}."
          },
          "description": {
            "type": "string",
            "description": "What this checkpoint validates"
          },
          "timeout_seconds": {
            "type": "integer",
            "minimum": 1,
            "default": 120,
            "description": "Maximum seconds to wait for this checkpoint verifier before timing out (default: 120)"
          }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "properties": {
        "required": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "code_patch",
              "config",
              "incident_report",
              "runbook",
              "reproduction_script",
              "kb_article",
              "security_assessment",
              "migration_guide",
              "answer",
              "topological_order"
            ]
          }
        },
        "optional": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "events": {
      "type": "object",
      "description": "Only for session_type=event_replay",
      "properties": {
        "event_file": {
          "type": "string",
          "description": "Path to events.jsonl"
        },
        "oracle_actions": {
          "type": "string",
          "description": "Path to oracle actions.jsonl for scoring"
        }
      }
    },
    "resume_state": {
      "type": "object",
      "description": "Only for session_type=resume",
      "properties": {
        "branch": {
          "type": "string",
          "description": "Pre-generated branch with partial progress"
        },
        "progress_doc": {
          "type": "string",
          "description": "Path to progress notes left by 'previous developer'"
        }
      }
    },
    "tool_access": {
      "type": "object",
      "description": "MCP tool access configuration and expected impact",
      "properties": {
        "expected_mcp_benefit": {
          "type": "string",
          "enum": ["high", "medium", "low"],
          "description": "Expected benefit from MCP tools (high = multi-repo cross-reference, low = single-file fix)"
        },
        "mcp_benefit_rationale": {
          "type": "string",
          "description": "Why MCP tools are expected to help (or not) for this task"
        },
        "sourcegraph_mirrors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "repo": {
                "type": "string",
                "description": "Repository identifier in sg-evals mirror"
              },
              "mirror_id": {
                "type": "string",
                "description": "sg-evals mirror identifier"
              }
            }
          },
          "description": "Sourcegraph sg-evals mirror references for this task's repos"
        }
      }
    },
    "difficulty_stratum": {
      "type": "string",
      "enum": [
        "calibration",
        "large_single",
        "dual_repo",
        "multi_repo",
        "monorepo_cross_package",
        "tri_repo"
      ],
      "description": "Task mix stratum for benchmark distribution (15% calibration, 25% large_single, 30% dual_repo, 20% multi_repo, 10% monorepo)"
    },
    "ground_truth": {
      "type": "object",
      "description": "Layered ground truth for context retrieval evaluation",
      "properties": {
        "tiers": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["deterministic", "curator", "solve_verified"]
          },
          "description": "Which ground truth tiers have been completed for this task"
        },
        "required_files": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "description": "File path relative to /workspace/{repo}/"
              },
              "repo": {
                "type": "string",
                "description": "Which repo this file belongs to"
              },
              "line_range": {
                "type": "string",
                "description": "Relevant line range (e.g., '45-120'), null for entire file"
              },
              "confidence": {
                "type": "number",
                "minimum": 0,
                "maximum": 1,
                "description": "Confidence score from ground truth pipeline"
              },
              "source": {
                "type": "string",
                "enum": ["deterministic", "curator", "both"],
                "description": "Which tier identified this file as required"
              }
            },
            "required": ["path", "repo"]
          },
          "description": "Files that MUST be found — missing = significant penalty"
        },
        "sufficient_files": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "description": "File path relative to /workspace/{repo}/"
              },
              "repo": {
                "type": "string",
                "description": "Which repo this file belongs to"
              },
              "line_range": {
                "type": "string",
                "description": "Relevant line range, null for entire file"
              },
              "confidence": {
                "type": "number",
                "minimum": 0,
                "maximum": 1,
                "description": "Confidence score from ground truth pipeline"
              }
            },
            "required": ["path", "repo"]
          },
          "description": "Files that help but are not essential — missing = small penalty"
        }
      }
    },
    "csb_lineage": {
      "type": "object",
      "description": "Provenance tracking for tasks migrated from CodeScaleBench (CSB)",
      "properties": {
        "parent_csb_id": {
          "type": "string",
          "description": "Original CSB task ID"
        },
        "origin_suite": {
          "type": "string",
          "description": "Original CSB suite (e.g., csb_org_compliance)"
        },
        "migration_status": {
          "type": "string",
          "enum": [
            "pending",
            "schema_mapped",
            "metadata_merged",
            "verified",
            "complete"
          ],
          "description": "Current stage in the CSB-to-EnterpriseBench migration pipeline"
        },
        "bugs_fixed": {
          "type": "array",
          "items": { "type": "string" },
          "description": "CSB bug IDs fixed during migration (cross-ref docs/csb_bugs.md)"
        },
        "metadata_sources": {
          "type": "array",
          "items": { "type": "string" },
          "description": "CSB files merged into this task (e.g., task.toml, ground_truth_meta.json)"
        }
      }
    },
    "mcp_suite": {
      "type": "string",
      "enum": ["eb_v1"],
      "description": "Benchmark suite identifier for grouping tasks into versioned evaluation sets"
    },
    "repo_set_id": {
      "type": "string",
      "description": "Semantic repo grouping identifier (e.g., kubernetes-ecosystem, grpc-ecosystem). Tasks sharing the same repos or closely related repos share a repo_set_id.",
      "pattern": "^[a-z][a-z0-9-]+$"
    },
    "org_scale": {
      "type": "boolean",
      "description": "Whether this task requires enterprise-scale codebase complexity (large repos, deep dependency chains, multi-repo interactions). Calibration tasks and small single-repo tasks are false."
    },
    "verification_modes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "deterministic",
          "llm_curator",
          "solve_verified",
          "structural_match"
        ]
      },
      "minItems": 1,
      "uniqueItems": true,
      "description": "Verification strategies used for this task's checkpoints (deterministic = exact match/script, llm_curator = LLM-judged, solve_verified = solve-then-compare, structural_match = structural/pattern validation)"
    }
  }
}
